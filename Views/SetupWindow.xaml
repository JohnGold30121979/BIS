<Window x:Class="BIS.ERP.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:BIS.ERP.Behaviors"
        xmlns:converters="clr-namespace:BIS.ERP.Converters"
        Title="Настройка подключения к PostgreSQL"
        Height="600" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Border Background="{DynamicResource AppWindowBackgroundBrush}" CornerRadius="10" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" Text="BIS ERP" FontSize="28" FontWeight="Bold" 
                       Foreground="{DynamicResource AppBodyTextBrush}" HorizontalAlignment="Center"
                       Margin="0,0,0,5"/>

            <TextBlock Grid.Row="1" Text="Настройка подключения к PostgreSQL" 
                       FontSize="14" Foreground="{DynamicResource AppSecondaryTextBrush}" HorizontalAlignment="Center" 
                       Margin="0,0,0,25"/>

            <!-- Сервер -->
            <TextBlock Grid.Row="2" Text="Сервер (Host)" Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="HostBox" Grid.Row="3" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Height="35" 
                     Padding="10,5" Margin="0,0,0,15"
                     Background="{DynamicResource AppInputBackgroundBrush}" Foreground="{DynamicResource AppInputForegroundBrush}"/>

            <!-- Порт -->
            <TextBlock Grid.Row="4" Text="Порт" Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="PortBox" Grid.Row="5" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Height="35" 
                     Padding="10,5" Margin="0,0,0,15"
                     Background="{DynamicResource AppInputBackgroundBrush}" Foreground="{DynamicResource AppInputForegroundBrush}"/>

            <!-- Пользователь -->
            <TextBlock Grid.Row="6" Text="Пользователь" Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameBox" Grid.Row="7" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Height="35" 
                     Padding="10,5" Margin="0,0,0,15"
                     Background="{DynamicResource AppInputBackgroundBrush}" Foreground="{DynamicResource AppInputForegroundBrush}"/>

            <!-- Пароль -->
            <TextBlock Grid.Row="8" Text="Пароль" Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="9" Height="35" 
                         Padding="10,5" Margin="0,0,0,20"
                         Background="{DynamicResource AppInputBackgroundBrush}" Foreground="{DynamicResource AppInputForegroundBrush}"
                         behaviors:PasswordBoxBindingBehavior.BindPassword="True"
                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="10" Text="Стиль интерфейса" Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,5"/>
            <ComboBox Grid.Row="11" Height="35" Margin="0,0,0,15"
                      SelectedValuePath="Tag"
                      SelectedValue="{Binding Theme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Content="По умолчанию" Tag="Default"/>
                <ComboBoxItem Content="Темный" Tag="Dark"/>
                <ComboBoxItem Content="Dracula" Tag="Dracula"/>
            </ComboBox>

            <!-- Кнопки -->
            <Button x:Name="TestButton" Grid.Row="12" Content="Проверить подключение" 
                    Height="40" Margin="0,5,0,10" Background="#3498DB" 
                    Foreground="White" Command="{Binding TestCommand}"
                    FontSize="13" FontWeight="SemiBold"/>

            <TextBlock x:Name="TestResultText" Grid.Row="13" Foreground="{Binding TestResultBrush}" 
                       Text="{Binding TestResult}"
                       Visibility="{Binding HasTestResult, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,10" 
                       TextAlignment="Center" TextWrapping="Wrap"/>

            <Button x:Name="SaveButton" Grid.Row="14" Content="Сохранить" Height="40" 
                    Background="#27AE60" Foreground="White" Command="{Binding SaveCommand}"
                    FontSize="13" FontWeight="SemiBold" Margin="0,5,0,0"/>
        </Grid>
    </Border>
</Window>
