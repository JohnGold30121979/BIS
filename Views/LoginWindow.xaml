<Window x:Class="BIS.ERP.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:BIS.ERP.Behaviors"
        xmlns:converters="clr-namespace:BIS.ERP.Converters"
        Title="BIS ERP - Вход в систему" 
        Height="450" Width="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Border Background="#2C3E50" CornerRadius="10" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <StackPanel Margin="30,35,35,11">
            <TextBlock Text="BIS ERP" FontSize="28" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock Text="Вход в систему" FontSize="14" 
                       Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,35"/>

            <TextBlock Text="Логин" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="LoginBox" Height="40" Padding="10,8" 
                     FontSize="16" Margin="0,0,0,20" Background="White" Foreground="#333"
                     TabIndex="0" PreviewKeyDown="OnLoginPreviewKeyDown"
                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Пароль" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Height="40" Padding="10,8" 
                         FontSize="16" Margin="0,0,0,25" Background="White" Foreground="#333"
                         TabIndex="1" PreviewKeyDown="OnPasswordPreviewKeyDown"
                         behaviors:PasswordBoxBindingBehavior.BindPassword="True"
                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock x:Name="ErrorText" Text="{Binding ErrorMessage}" Foreground="#E74C3C" 
                       FontSize="12" TextAlignment="Center" 
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,15">
                <Button x:Name="LoginButton" Content="Войти" Width="120" Height="40"
                        Background="#3498DB" Foreground="White" FontSize="14" FontWeight="Bold"
                        Command="{Binding LoginCommand}" Margin="0,0,15,0" Cursor="Hand" TabIndex="2"
                        IsDefault="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="RegisterButton" Content="Регистрация" Width="120" Height="40"
                        Background="Transparent" Foreground="White" FontSize="14"
                        BorderBrush="#3498DB" BorderThickness="1" Command="{Binding RegisterCommand}" Cursor="Hand" TabIndex="3">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <Button x:Name="ExitButton" Content="Выход" 
                    Width="100" Height="35" Background="#E74C3C" 
                    Foreground="White" FontSize="13" FontWeight="SemiBold"
                    BorderThickness="0" Command="{Binding CloseCommand}" Cursor="Hand" 
                    HorizontalAlignment="Center" Margin="0,10,0,0" TabIndex="4">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>
