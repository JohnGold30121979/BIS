<Window x:Class="BIS.ERP.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIS ERP - Вход в систему" 
        Height="500" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#2C3E50" CornerRadius="10" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30,40" VerticalAlignment="Center">
                <TextBlock Text="BIS ERP" FontSize="32" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="Вход в систему" FontSize="16" 
                           Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <TextBlock Text="Логин" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
                <TextBox x:Name="LoginBox" Height="40" Padding="10,5" 
                         FontSize="14" Margin="0,0,0,20" Background="White" Foreground="#333"/>

                <TextBlock Text="Пароль" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="40" Padding="10,5" 
                             FontSize="14" Margin="0,0,0,25" Background="White" Foreground="#333"/>

                <TextBlock x:Name="ErrorText" Foreground="#E74C3C" 
                           FontSize="12" TextAlignment="Center" 
                           Visibility="Collapsed" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,20">
                    <Button x:Name="LoginButton" Content="Войти" Width="130" Height="42"
                            Background="#3498DB" Foreground="White" FontSize="14" FontWeight="Bold"
                            Click="OnLoginClick" Margin="0,0,15,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="RegisterButton" Content="Регистрация" Width="130" Height="42"
                            Background="Transparent" Foreground="White" FontSize="14"
                            BorderBrush="#3498DB" BorderThickness="1" Click="OnRegisterClick" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Button x:Name="ExitButton" Content="Выход" 
                        Width="100" Height="35" Background="Transparent" 
                        Foreground="#7F8C8D" FontSize="12" BorderThickness="0"
                        Click="OnExitClick" HorizontalAlignment="Center" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>