<Window x:Class="BIS.ERP.Views.ReportDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конструктор отчетов - BIS ERP"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PreviewButton" Content="👁️ Предпросмотр" 
                        Width="110" Height="35" Margin="5"
                        Background="#3498DB" Foreground="White" Click="OnPreviewClick"/>
                <Button x:Name="SaveButton" Content="💾 Сохранить" 
                        Width="110" Height="35" Margin="5"
                        Background="#27AE60" Foreground="White" Click="OnSaveClick"/>
                <Button x:Name="PdfButton" Content="PDF" ToolTip="Сформировать отчет в PDF"
                        Width="100" Height="35" Margin="5"
                        Background="#34495E" Foreground="White" Click="OnExportPdfClick"/>
                <Button x:Name="CancelButton" Content="❌ Отмена" 
                        Width="90" Height="35" Margin="5"
                        Background="#95A5A6" Foreground="White" Click="OnCancelClick"/>

                <Separator Width="20" Opacity="0"/>

                <TextBlock x:Name="StatusText" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое с вкладками -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- Вкладка: Общие -->

            <!-- Вкладка: Общие -->
            <TabItem Header="📋 Общие">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Padding="20" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Row 0: Название -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="ReportNameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Height="35" Margin="0,5"/>

                            <!-- Row 1: Описание -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание:" VerticalAlignment="Top" FontWeight="Bold" Margin="0,5"/>
                            <TextBox x:Name="ReportDescBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Height="60" TextWrapping="Wrap" Margin="0,5"/>

                            <!-- Row 2: Источник + Тип отчета -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Источник:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="DataSourceCombo" Grid.Row="2" Grid.Column="1" Height="35" Margin="5"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Тип отчета:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="ReportTypeCombo" Grid.Row="2" Grid.Column="3" Height="35" Margin="5" SelectedIndex="0">
                                <ComboBoxItem Content="Таблица" Tag="Table"/>
                                <ComboBoxItem Content="Список" Tag="List"/>
                                <ComboBoxItem Content="Карточка" Tag="Card"/>
                                <ComboBoxItem Content="Счет-фактура на материалы (КР)" Tag="InvoiceMaterialsKg"/>
                                <ComboBoxItem Content="Приходный кассовый ордер" Tag="CashReceiptOrder"/>
                                <ComboBoxItem Content="Расходный кассовый ордер" Tag="CashPaymentOrder"/>
                                <ComboBoxItem Content="Макет Visual FoxPro FRX" Tag="FoxProLayout"/>
                            </ComboBox>

                            <!-- Row 3: Заголовок -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Заголовок:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="TitleTextBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Height="35" Margin="5"/>

                            <!-- Row 4: Подзаголовок -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Подзаголовок:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="SubtitleTextBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Height="35" Margin="5"/>

                            <!-- Row 5: Текст в шапке -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Текст в шапке:" VerticalAlignment="Top" FontWeight="Bold"/>
                            <TextBox x:Name="HeaderTextBox" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Height="60" TextWrapping="Wrap" Margin="5"/>

                            <!-- Row 6: Текст в подвале -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Текст в подвале:" VerticalAlignment="Top" FontWeight="Bold"/>
                            <TextBox x:Name="FooterTextBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Height="60" TextWrapping="Wrap" Margin="5"/>

                            <!-- Row 7: Итоговый текст -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Итоговый текст:" VerticalAlignment="Top" FontWeight="Bold"/>
                            <TextBox x:Name="SummaryTextBox" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" Height="60" TextWrapping="Wrap" Margin="5"/>

                            <!-- Row 8: FRX-шаблон с кнопкой загрузки -->
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="FRX-шаблон:" VerticalAlignment="Top" FontWeight="Bold" Margin="0,5"/>
                            <Grid Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Content="📂 Загрузить FRX-файл" 
                            Width="160" Height="30" Margin="0,0,0,5"
                            Background="#E67E22" Foreground="White" 
                            Click="OnLoadFrxClick"
                            HorizontalAlignment="Left"
                            Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <TextBox x:Name="TemplateTextBox" Grid.Row="1" 
                             Height="150" TextWrapping="Wrap" AcceptsReturn="True" 
                             FontFamily="Consolas" FontSize="11" 
                             ToolTip="JSON-описание макета FoxPro"/>
                            </Grid>

                            <!-- Row 9: Чекбоксы -->
                            <StackPanel Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="5,12,5,0">
                                <CheckBox x:Name="IsActiveCheck" Content="Отчет доступен" IsChecked="True" Margin="0,0,20,0"/>
                                <CheckBox x:Name="IsPrintFormCheck" Content="Печатная форма документа" Margin="0,0,20,0"/>
                                <CheckBox x:Name="IsDefaultCheck" Content="По умолчанию"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка: Поля -->
            <TabItem Header="📊 Поля">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Доступные поля -->
                    <Border Grid.Column="0" Background="#F0F4F8" Margin="0,0,10,0">
                        <StackPanel Margin="10">
                            <TextBlock Text="📋 Доступные поля" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <ListBox x:Name="AvailableFields" Height="500" 
                                     MouseDoubleClick="OnFieldDoubleClick"
                                     SelectionMode="Extended">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8" Margin="0,1" Background="White" CornerRadius="5">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📄" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text=" (" Foreground="#666"/>
                                                <TextBlock Text="{Binding Type}" Foreground="#666"/>
                                                <TextBlock Text=")" Foreground="#666"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Поля отчета -->
                    <Border Grid.Column="1" Background="White">
                        <StackPanel Margin="10">
                            <TextBlock Text="📋 Поля отчета" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <DataGrid x:Name="ReportFieldsGrid" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      RowHeight="40" MaxHeight="450">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Имя поля" Binding="{Binding FieldName}" Width="120" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Отображаемое имя" Binding="{Binding DisplayName}" Width="150"/>
                                    <DataGridComboBoxColumn Header="Тип агрегации" Width="120"/>
                                    <DataGridTextColumn Header="Ширина" Binding="{Binding Width}" Width="80"/>
                                    <DataGridCheckBoxColumn Header="Видимость" Binding="{Binding IsVisible}" Width="80"/>
                                    <DataGridComboBoxColumn Header="Выравнивание" Width="100"/>
                                    <DataGridTemplateColumn Header="Удалить" Width="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="❌" Width="30" Height="30"
                                                        Background="Transparent" Click="OnRemoveFieldClick"
                                                        Cursor="Hand"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button x:Name="MoveUpButton" Content="⬆ Вверх" Width="80" Height="30" Margin="0,0,5,0"
                                        Background="#3498DB" Foreground="White" Click="OnMoveUpClick"/>
                                <Button x:Name="MoveDownButton" Content="⬇ Вниз" Width="80" Height="30"
                                        Background="#3498DB" Foreground="White" Click="OnMoveDownClick"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка: Оформление -->            
            <TabItem Header="🎨 Оформление">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Padding="20" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ориентация:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="OrientationCombo" Grid.Row="0" Grid.Column="1" Height="35" Margin="5" SelectedIndex="0">
                                <ComboBoxItem>Книжная</ComboBoxItem>
                                <ComboBoxItem>Альбомная</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Шрифт:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="FontCombo" Grid.Row="0" Grid.Column="3" Height="35" Margin="5" SelectedIndex="0">
                                <ComboBoxItem>Segoe UI</ComboBoxItem>
                                <ComboBoxItem>Arial</ComboBoxItem>
                                <ComboBoxItem>Times New Roman</ComboBoxItem>
                                <ComboBoxItem>Calibri</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Размер шрифта:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="FontSizeCombo" Grid.Row="1" Grid.Column="1" Height="35" Margin="5" SelectedIndex="2">
                                <ComboBoxItem>8</ComboBoxItem>
                                <ComboBoxItem>9</ComboBoxItem>
                                <ComboBoxItem>10</ComboBoxItem>
                                <ComboBoxItem>11</ComboBoxItem>
                                <ComboBoxItem>12</ComboBoxItem>
                                <ComboBoxItem>14</ComboBoxItem>
                                <ComboBoxItem>16</ComboBoxItem>
                                <ComboBoxItem>18</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Цвет шапки:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="HeaderColorCombo" Grid.Row="1" Grid.Column="3" Height="35" Margin="5" SelectedIndex="0">
                                <ComboBoxItem Tag="#2C3E50">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#2C3E50" Margin="0,0,10,0"/>
                                        <TextBlock>Темно-синий</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="#3498DB">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#3498DB" Margin="0,0,10,0"/>
                                        <TextBlock>Синий</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="#27AE60">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#27AE60" Margin="0,0,10,0"/>
                                        <TextBlock>Зеленый</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="#E74C3C">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#E74C3C" Margin="0,0,10,0"/>
                                        <TextBlock>Красный</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="#9B59B6">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#9B59B6" Margin="0,0,10,0"/>
                                        <TextBlock>Фиолетовый</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                            </ComboBox>

                            <CheckBox x:Name="AlternateRowColorsCheck" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" 
                          Content="✓ Чередовать цвета строк" Margin="5" IsChecked="True"/>

                            <CheckBox x:Name="ShowGridLinesCheck" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" 
                          Content="✓ Показывать линии сетки" Margin="5" IsChecked="True"/>

                            <CheckBox x:Name="ShowGrandTotalCheck" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" 
                          Content="✓ Показывать общий итог" Margin="5" IsChecked="True"/>

                            <CheckBox x:Name="ShowPageNumbersCheck" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" 
                          Content="✓ Показывать номера страниц" Margin="5" IsChecked="True"/>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка: Фильтры -->
            <TabItem Header="🔍 Фильтры">
                <Border Padding="20" Background="White">
                    <StackPanel>
                        <TextBlock Text="Условия отбора" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                        <Button x:Name="AddFilterButton" Content="➕ Добавить условие" 
                                Width="150" Height="35" Margin="0,0,0,15"
                                Background="#3498DB" Foreground="White" Click="OnAddFilterClick"/>

                        <ItemsControl x:Name="FiltersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <ComboBox x:Name="FilterField" Grid.Column="0" Height="30" Margin="5"
                                                      ItemsSource="{Binding DataContext.AvailableFilterFields, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      DisplayMemberPath="Name" SelectedValuePath="DbColumnName"
                                                      SelectedValue="{Binding FieldName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <ComboBox x:Name="FilterOp" Grid.Column="1" Height="30" Margin="5"
                                                      SelectedValuePath="Content"
                                                      SelectedValue="{Binding Operation, Mode=TwoWay}">
                                                <ComboBoxItem>=</ComboBoxItem>
                                                <ComboBoxItem>&lt;</ComboBoxItem>
                                                <ComboBoxItem>&gt;</ComboBoxItem>
                                                <ComboBoxItem>&lt;=</ComboBoxItem>
                                                <ComboBoxItem>&gt;=</ComboBoxItem>
                                                <ComboBoxItem>Like</ComboBoxItem>
                                            </ComboBox>
                                            <TextBox x:Name="FilterValue" Grid.Column="2" Height="30" Margin="5" Text="{Binding Value}"/>
                                            <Button Content="❌" Grid.Column="3" Width="30" Height="30" Margin="5"
                                                    Background="Transparent" Click="RemoveFilter_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="#F0F4F8" Padding="10">
            <TextBlock x:Name="InfoText" Text="Готово" Foreground="#666"/>
        </Border>
    </Grid>
</Window>
