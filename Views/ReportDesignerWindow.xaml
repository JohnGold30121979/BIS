<Window x:Class="BIS.ERP.Views.ReportDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конструктор отчетов - BIS ERP"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PreviewButton" Content="👁️ Предпросмотр" 
                        Width="110" Height="35" Margin="5"
                        Background="#3498DB" Foreground="White" Click="OnPreviewClick"/>
                <Button x:Name="SaveButton" Content="💾 Сохранить" 
                        Width="110" Height="35" Margin="5"
                        Background="#27AE60" Foreground="White" Click="OnSaveClick"/>
                <Button x:Name="PdfButton" Content="PDF" ToolTip="Сформировать отчет в PDF"
                        Width="100" Height="35" Margin="5"
                        Background="#34495E" Foreground="White" Click="OnExportPdfClick"/>
                <Button x:Name="CancelButton" Content="❌ Отмена" 
                        Width="90" Height="35" Margin="5"
                        Background="#95A5A6" Foreground="White" Click="OnCancelClick"/>

                <Separator Width="20" Opacity="0"/>

                <TextBlock x:Name="StatusText" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое с вкладками -->
        <TabControl Grid.Row="1" Margin="10">
            <!-- Вкладка: Общие -->

            <!-- Вкладка: Общие -->
            <TabItem Header="📋 Общие">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Padding="20" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Row 0: Название -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="ReportNameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Height="35" Margin="0,5"/>

                            <!-- Row 1: Описание -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание:" VerticalAlignment="Top" FontWeight="Bold" Margin="0,5"/>
                            <TextBox x:Name="ReportDescBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Height="60" TextWrapping="Wrap" Margin="0,5"/>

                            <!-- Row 2: Источник + Тип отчета -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Источник:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="DataSourceCombo" Grid.Row="2" Grid.Column="1" Height="35" Margin="5"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Тип отчета:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="ReportTypeCombo" Grid.Row="2" Grid.Column="3" Height="35" Margin="5" SelectedIndex="0"
                                      SelectionChanged="OnReportTypeChanged">
                                <ComboBoxItem Content="Таблица" Tag="Table"/>
                                <ComboBoxItem Content="Список" Tag="List"/>
                                <ComboBoxItem Content="Карточка" Tag="Card"/>
                                <ComboBoxItem Content="Счет-фактура на материалы (КР)" Tag="InvoiceMaterialsKg"/>
                                <ComboBoxItem Content="Приходный кассовый ордер" Tag="CashReceiptOrder"/>
                                <ComboBoxItem Content="Расходный кассовый ордер" Tag="CashPaymentOrder"/>
                                <ComboBoxItem Content="Макет Visual FoxPro FRX" Tag="FoxProLayout"/>
                            </ComboBox>

                            <!-- Row 3: Заголовок -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Заголовок:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="TitleTextBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Height="35" Margin="5"/>

                            <!-- Row 4: Подзаголовок -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Подзаголовок:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="SubtitleTextBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Height="35" Margin="5"/>

                            <!-- Row 5: Текст в шапке -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Текст в шапке:" VerticalAlignment="Top" FontWeight="Bold"/>
                            <TextBox x:Name="HeaderTextBox" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Height="60" TextWrapping="Wrap" Margin="5"/>

                            <!-- Row 6: Текст в подвале -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Текст в подвале:" VerticalAlignment="Top" FontWeight="Bold"/>
                            <TextBox x:Name="FooterTextBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Height="60" TextWrapping="Wrap" Margin="5"/>

                            <!-- Row 7: Итоговый текст -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Итоговый текст:" VerticalAlignment="Top" FontWeight="Bold"/>
                            <TextBox x:Name="SummaryTextBox" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" Height="60" TextWrapping="Wrap" Margin="5"/>

                            <!-- Row 8: FRX-шаблон с кнопкой загрузки -->
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="FRX-шаблон:" VerticalAlignment="Top" FontWeight="Bold" Margin="0,5"/>
                            <Grid Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0" Content="📂 Загрузить FRX-файл" 
                            Width="160" Height="30" Margin="0,0,0,5"
                            Background="#E67E22" Foreground="White" 
                            Click="OnLoadFrxClick"
                            HorizontalAlignment="Left"
                            Cursor="Hand"/>

                                <TextBox x:Name="TemplateTextBox" Grid.Row="1" 
                             Height="150" TextWrapping="Wrap" AcceptsReturn="True" 
                             FontFamily="Consolas" FontSize="11" 
                             ToolTip="JSON-описание макета FoxPro"/>
                            </Grid>

                            <!-- Row 9: Чекбоксы -->
                            <StackPanel Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="5,12,5,0">
                                <CheckBox x:Name="IsActiveCheck" Content="Отчет доступен" IsChecked="True" Margin="0,0,20,0"/>
                                <CheckBox x:Name="IsPrintFormCheck" Content="Печатная форма документа" Margin="0,0,20,0"/>
                                <CheckBox x:Name="IsDefaultCheck" Content="По умолчанию"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка: Поля -->
            <TabItem Header="📊 Поля">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Доступные поля -->
                    <Border Grid.Column="0" Background="#F0F4F8" Margin="0,0,10,0">
                        <StackPanel Margin="10">
                            <TextBlock Text="📋 Доступные поля" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <ListBox x:Name="AvailableFields" Height="500"
                                     ItemsSource="{Binding AvailableSourceFields}"
                                     MouseDoubleClick="OnFieldDoubleClick"
                                     SelectionMode="Extended">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8" Margin="0,1" Background="White" CornerRadius="5">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📄" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text=" (" Foreground="#666"/>
                                                <TextBlock Text="{Binding Type}" Foreground="#666"/>
                                                <TextBlock Text=")" Foreground="#666"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Поля отчета -->
                    <Border Grid.Column="1" Background="White">
                        <StackPanel Margin="10">
                            <TextBlock Text="📋 Поля отчета" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                            <DataGrid x:Name="ReportFieldsGrid" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      RowHeight="40" MaxHeight="450">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Имя поля" Binding="{Binding FieldName}" Width="120" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Отображаемое имя" Binding="{Binding DisplayName}" Width="150"/>
                                    <DataGridComboBoxColumn Header="Тип агрегации" Width="120"/>
                                    <DataGridTextColumn Header="Ширина" Binding="{Binding Width}" Width="80"/>
                                    <DataGridCheckBoxColumn Header="Видимость" Binding="{Binding IsVisible}" Width="80"/>
                                    <DataGridComboBoxColumn Header="Выравнивание" Width="100"/>
                                    <DataGridTemplateColumn Header="Удалить" Width="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="❌" Width="30" Height="30"
                                                        Background="Transparent" Click="OnRemoveFieldClick"
                                                        Cursor="Hand"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button x:Name="MoveUpButton" Content="⬆ Вверх" Width="80" Height="30" Margin="0,0,5,0"
                                        Background="#3498DB" Foreground="White" Click="OnMoveUpClick"/>
                                <Button x:Name="MoveDownButton" Content="⬇ Вниз" Width="80" Height="30"
                                        Background="#3498DB" Foreground="White" Click="OnMoveDownClick"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка: Соответствия полей (только для FRX) -->
            <TabItem Header="🔗 FRX поля" x:Name="FrXFieldsTab">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Padding="15" Background="White">
                        <StackPanel>
                            <TextBlock Text="Соответствие элементов макета полям данных" 
                                       FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                            
                            <DataGrid x:Name="ElementMappingGrid" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      RowHeight="45" MaxHeight="500" Margin="0,0,0,15"
                                      CurrentCellChanged="OnElementMappingChanged"
                                      CellEditEnding="OnElementMappingCellEditEnding">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Элемент" Binding="{Binding ElementText}" Width="120" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Тип" Binding="{Binding ElementType}" Width="70" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Положение (L/T)" Binding="{Binding LeftTop}" Width="90" IsReadOnly="True"/>
                                    <DataGridTemplateColumn Header="Поле данных" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.AvailableDataFields, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="DbColumnName"
                                                          SelectedValue="{Binding MappedFieldName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Height="25" Margin="2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Формат" Binding="{Binding FormatString}" Width="100"/>
                                    <DataGridTextColumn Header="Свой текст" Binding="{Binding CustomText}" Width="160"/>
                                    <DataGridCheckBoxColumn Header="Видимость" Binding="{Binding IsVisible}" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Text="💡 Для каждого элемента макета выберите, какое поле данных в него подставлять." 
                                       FontSize="11" Foreground="Gray" Margin="0,0,0,10"/>

                            <Separator Margin="0,0,0,10"/>

                            <TextBlock Text="Предпросмотр соответствий" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#F8F9FA" Padding="10" CornerRadius="5">
                                <TextBlock x:Name="MappingPreviewText" FontSize="11" Foreground="#333" 
                                           TextWrapping="Wrap" Text="Загрузите FRX-макет, чтобы увидеть соответствия."/>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка: Нативный визуальный макет -->
            <TabItem Header="🧱 Нативный макет" x:Name="NativeDesignerTab"
                     PreviewKeyDown="OnNativeDesignerPreviewKeyDown">
                <Grid Background="#F4F6F8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" Margin="0,0,10,0" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Элементы макета" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ComboBox x:Name="NativeBandCombo" Height="30" Margin="0,0,0,8" SelectedIndex="1">
                                <ComboBoxItem Content="Header"/>
                                <ComboBoxItem Content="Body"/>
                                <ComboBoxItem Content="Footer"/>
                            </ComboBox>

                            <WrapPanel Margin="0,0,0,10">
                                <Button Content="+ Элемент" Width="100" Height="30" Margin="0,0,6,6"
                                        Background="#27AE60" Foreground="White" Click="OnAddNativeElementClick"/>
                                <Button Content="- Удалить" Width="100" Height="30" Margin="0,0,6,6"
                                        Background="#C0392B" Foreground="White" Click="OnDeleteNativeElementClick"/>
                                <Button Content="Текст" Width="78" Height="30" Margin="0,0,6,6" Click="OnAddNativeTextClick"/>
                                <Button Content="Поле" Width="78" Height="30" Margin="0,0,6,6" Click="OnAddNativeFieldClick"/>
                                <Button Content="Линия" Width="78" Height="30" Margin="0,0,6,6" Click="OnAddNativeLineClick"/>
                                <Button Content="Рамка" Width="78" Height="30" Margin="0,0,6,6" Click="OnAddNativeBoxClick"/>
                            </WrapPanel>

                            <Button Content="Новый пустой макет" Height="32" Margin="0,0,0,10"
                                    Background="#34495E" Foreground="White" Click="OnNewBlankNativeTemplateClick"/>

                            <DataGrid x:Name="NativeElementsGrid" AutoGenerateColumns="False"
                                      Height="420" CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionChanged="OnNativeElementGridSelectionChanged"
                                      CellEditEnding="OnNativeElementCellEditEnding">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Order}" Width="40" IsReadOnly="True"/>
                                    <DataGridComboBoxColumn Header="Тип" SelectedValueBinding="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="85">
                                        <DataGridComboBoxColumn.ItemsSource>
                                            <x:Array Type="{x:Type sys:String}" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                <sys:String>Text</sys:String>
                                                <sys:String>Expression</sys:String>
                                                <sys:String>Line</sys:String>
                                                <sys:String>Box</sys:String>
                                            </x:Array>
                                        </DataGridComboBoxColumn.ItemsSource>
                                    </DataGridComboBoxColumn>
                                    <DataGridComboBoxColumn Header="Блок" SelectedValueBinding="{Binding BandType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="85">
                                        <DataGridComboBoxColumn.ItemsSource>
                                            <x:Array Type="{x:Type sys:String}" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                <sys:String>Header</sys:String>
                                                <sys:String>Body</sys:String>
                                                <sys:String>Footer</sys:String>
                                            </x:Array>
                                        </DataGridComboBoxColumn.ItemsSource>
                                    </DataGridComboBoxColumn>
                                    <DataGridTextColumn Header="Текст" Binding="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                    <DataGridTemplateColumn Header="Поле" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.AvailableDataFields, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="DbColumnName"
                                                          SelectedValue="{Binding Expression, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Height="24"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="X" Binding="{Binding Left, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=0}" Width="55"/>
                                    <DataGridTextColumn Header="Y" Binding="{Binding Top, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=0}" Width="55"/>
                                    <DataGridTextColumn Header="Ш" Binding="{Binding Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=0}" Width="55"/>
                                    <DataGridTextColumn Header="В" Binding="{Binding Height, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=0}" Width="55"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#D9DEE5" Padding="16">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Canvas x:Name="NativeDesignerCanvas"
                                        Background="White"
                                        Focusable="True"
                                        PreviewKeyDown="OnNativeDesignerPreviewKeyDown"
                                        MouseMove="OnNativeDesignerMouseMove"
                                        MouseLeftButtonUp="OnNativeDesignerMouseLeftButtonUp"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Background="White" Margin="10,0,0,0" Padding="12">
                        <Grid PreviewKeyDown="OnNativePropertiesPreviewKeyDown">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Свойства элемента"
                                       FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Текст:" VerticalAlignment="Center"/>
                            <TextBox x:Name="NativeTextBox" Grid.Row="1" Grid.Column="1" Height="28" Margin="0,3"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Поле:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="NativeFieldCombo" Grid.Row="2" Grid.Column="1" Height="28" Margin="0,3"
                                      ItemsSource="{Binding AvailableDataFields}"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="DbColumnName"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="X/Y:" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <Grid Width="82" Height="30" Margin="0,3,8,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NativeLeftBox" Height="28" VerticalContentAlignment="Center"/>
                                    <UniformGrid Grid.Column="1" Rows="2">
                                        <Button Content="+" Padding="0" FontSize="9" Tag="Left:+1" Click="OnNativeGeometrySpinClick"/>
                                        <Button Content="-" Padding="0" FontSize="9" Tag="Left:-1" Click="OnNativeGeometrySpinClick"/>
                                    </UniformGrid>
                                </Grid>
                                <Grid Width="82" Height="30" Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NativeTopBox" Height="28" VerticalContentAlignment="Center"/>
                                    <UniformGrid Grid.Column="1" Rows="2">
                                        <Button Content="+" Padding="0" FontSize="9" Tag="Top:+1" Click="OnNativeGeometrySpinClick"/>
                                        <Button Content="-" Padding="0" FontSize="9" Tag="Top:-1" Click="OnNativeGeometrySpinClick"/>
                                    </UniformGrid>
                                </Grid>
                            </StackPanel>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Ш/В:" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                                <Grid Width="82" Height="30" Margin="0,3,8,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NativeWidthBox" Height="28" VerticalContentAlignment="Center"/>
                                    <UniformGrid Grid.Column="1" Rows="2">
                                        <Button Content="+" Padding="0" FontSize="9" Tag="Width:+1" Click="OnNativeGeometrySpinClick"/>
                                        <Button Content="-" Padding="0" FontSize="9" Tag="Width:-1" Click="OnNativeGeometrySpinClick"/>
                                    </UniformGrid>
                                </Grid>
                                <Grid Width="82" Height="30" Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NativeHeightBox" Height="28" VerticalContentAlignment="Center"/>
                                    <UniformGrid Grid.Column="1" Rows="2">
                                        <Button Content="+" Padding="0" FontSize="9" Tag="Height:+1" Click="OnNativeGeometrySpinClick"/>
                                        <Button Content="-" Padding="0" FontSize="9" Tag="Height:-1" Click="OnNativeGeometrySpinClick"/>
                                    </UniformGrid>
                                </Grid>
                            </StackPanel>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Шрифт:" VerticalAlignment="Center"/>
                            <TextBox x:Name="NativeFontBox" Grid.Row="5" Grid.Column="1" Height="28" Margin="0,3"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Размер:" VerticalAlignment="Center"/>
                            <TextBox x:Name="NativeFontSizeBox" Grid.Row="6" Grid.Column="1" Height="28" Margin="0,3"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Выравн.:" VerticalAlignment="Center"/>
                            <ComboBox x:Name="NativeAlignmentCombo" Grid.Row="7" Grid.Column="1" Height="28" Margin="0,3">
                                <ComboBoxItem Content="Left"/>
                                <ComboBoxItem Content="Center"/>
                                <ComboBoxItem Content="Right"/>
                            </ComboBox>
                            <CheckBox x:Name="NativeBoldCheck" Grid.Row="8" Grid.Column="1" Content="Жирный" Margin="0,8,0,0"/>
                            <CheckBox x:Name="NativeItalicCheck" Grid.Row="9" Grid.Column="1" Content="Курсив" Margin="0,4,0,0"/>
                            <Button Grid.Row="10" Grid.ColumnSpan="2" Content="Применить свойства"
                                    Height="34" Margin="0,14,0,0"
                                    Background="#27AE60" Foreground="White"
                                    Click="OnApplyNativeElementPropertiesClick"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка: Оформление -->            
            <TabItem Header="🎨 Оформление">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Padding="20" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Ориентация:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="OrientationCombo" Grid.Row="0" Grid.Column="1" Height="35" Margin="5" SelectedIndex="0">
                                <ComboBoxItem>Книжная</ComboBoxItem>
                                <ComboBoxItem>Альбомная</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Шрифт:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="FontCombo" Grid.Row="0" Grid.Column="3" Height="35" Margin="5" SelectedIndex="0">
                                <ComboBoxItem>Segoe UI</ComboBoxItem>
                                <ComboBoxItem>Arial</ComboBoxItem>
                                <ComboBoxItem>Times New Roman</ComboBoxItem>
                                <ComboBoxItem>Calibri</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Размер шрифта:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="FontSizeCombo" Grid.Row="1" Grid.Column="1" Height="35" Margin="5" SelectedIndex="2">
                                <ComboBoxItem>8</ComboBoxItem>
                                <ComboBoxItem>9</ComboBoxItem>
                                <ComboBoxItem>10</ComboBoxItem>
                                <ComboBoxItem>11</ComboBoxItem>
                                <ComboBoxItem>12</ComboBoxItem>
                                <ComboBoxItem>14</ComboBoxItem>
                                <ComboBoxItem>16</ComboBoxItem>
                                <ComboBoxItem>18</ComboBoxItem>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Цвет шапки:" VerticalAlignment="Center" FontWeight="Bold"/>
                            <ComboBox x:Name="HeaderColorCombo" Grid.Row="1" Grid.Column="3" Height="35" Margin="5" SelectedIndex="0">
                                <ComboBoxItem Tag="#2C3E50">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#2C3E50" Margin="0,0,10,0"/>
                                        <TextBlock>Темно-синий</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="#3498DB">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#3498DB" Margin="0,0,10,0"/>
                                        <TextBlock>Синий</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="#27AE60">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#27AE60" Margin="0,0,10,0"/>
                                        <TextBlock>Зеленый</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="#E74C3C">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#E74C3C" Margin="0,0,10,0"/>
                                        <TextBlock>Красный</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem Tag="#9B59B6">
                                    <StackPanel Orientation="Horizontal">
                                        <Rectangle Width="20" Height="20" Fill="#9B59B6" Margin="0,0,10,0"/>
                                        <TextBlock>Фиолетовый</TextBlock>
                                    </StackPanel>
                                </ComboBoxItem>
                            </ComboBox>

                            <CheckBox x:Name="AlternateRowColorsCheck" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" 
                          Content="✓ Чередовать цвета строк" Margin="5" IsChecked="True"/>

                            <CheckBox x:Name="ShowGridLinesCheck" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" 
                          Content="✓ Показывать линии сетки" Margin="5" IsChecked="True"/>

                            <CheckBox x:Name="ShowGrandTotalCheck" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" 
                          Content="✓ Показывать общий итог" Margin="5" IsChecked="True"/>

                            <CheckBox x:Name="ShowPageNumbersCheck" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" 
                          Content="✓ Показывать номера страниц" Margin="5" IsChecked="True"/>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка: Фильтры -->
            <TabItem Header="🔍 Фильтры">
                <Border Padding="20" Background="White">
                    <StackPanel>
                        <TextBlock Text="Условия отбора" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                        <Button x:Name="AddFilterButton" Content="➕ Добавить условие" 
                                Width="150" Height="35" Margin="0,0,0,15"
                                Background="#3498DB" Foreground="White" Click="OnAddFilterClick"/>

                        <ItemsControl x:Name="FiltersList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <ComboBox x:Name="FilterField" Grid.Column="0" Height="30" Margin="5"
                                                      ItemsSource="{Binding DataContext.AvailableFilterFields, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      DisplayMemberPath="Name" SelectedValuePath="DbColumnName"
                                                      SelectedValue="{Binding FieldName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <ComboBox x:Name="FilterOp" Grid.Column="1" Height="30" Margin="5"
                                                      SelectedValuePath="Content"
                                                      SelectedValue="{Binding Operation, Mode=TwoWay}">
                                                <ComboBoxItem>=</ComboBoxItem>
                                                <ComboBoxItem>&lt;</ComboBoxItem>
                                                <ComboBoxItem>&gt;</ComboBoxItem>
                                                <ComboBoxItem>&lt;=</ComboBoxItem>
                                                <ComboBoxItem>&gt;=</ComboBoxItem>
                                                <ComboBoxItem>Like</ComboBoxItem>
                                            </ComboBox>
                                            <TextBox x:Name="FilterValue" Grid.Column="2" Height="30" Margin="5" Text="{Binding Value}"/>
                                            <Button Content="❌" Grid.Column="3" Width="30" Height="30" Margin="5"
                                                    Background="Transparent" Click="RemoveFilter_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="#F0F4F8" Padding="10">
            <TextBlock x:Name="InfoText" Text="Готово" Foreground="#666"/>
        </Border>
    </Grid>
</Window>
