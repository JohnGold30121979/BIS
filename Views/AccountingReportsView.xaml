<UserControl x:Class="BIS.ERP.Views.AccountingReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,15">
            <TextBlock Text="Бухгалтерская отчетность" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Баланс, финансовые результаты, журналы и контроль периода"
                       Foreground="Gray" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource AppSurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Отчет:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="ReportTypeCombo" Width="250" Height="32" SelectedIndex="0" SelectionChanged="OnReportTypeSelectionChanged">
                        <ComboBoxItem Tag="TrialBalance">Оборотно-сальдовая ведомость</ComboBoxItem>
                        <ComboBoxItem Tag="GeneralLedger">Главная книга</ComboBoxItem>
                        <ComboBoxItem Tag="FinancialPosition">Баланс предприятия</ComboBoxItem>
                        <ComboBoxItem Tag="FinancialResults">Финансовые результаты</ComboBoxItem>
                        <ComboBoxItem Tag="PurchaseSalesJournal">Журнал закупок и продаж</ComboBoxItem>
                        <ComboBoxItem Tag="OrganizationBalances">Сальдо по организациям</ComboBoxItem>
                        <ComboBoxItem Tag="PeriodCollection">Сбор информации за период</ComboBoxItem>
                        <ComboBoxItem Tag="CashBook">Кассовая книга</ComboBoxItem>
                        <ComboBoxItem Tag="PaymentOrderRegister">Реестр платежных поручений</ComboBoxItem>
                        <ComboBoxItem Tag="BankStatement">Выписка банка</ComboBoxItem>
                        <ComboBoxItem Tag="OrganizationReconciliation">Акт сверки</ComboBoxItem>
                    </ComboBox>
                    <TextBlock Text="С:" VerticalAlignment="Center" Margin="16,0,6,0"/>
                    <DatePicker x:Name="StartDatePicker" Width="130" Height="32"/>
                    <TextBlock Text="По:" VerticalAlignment="Center" Margin="12,0,6,0"/>
                    <DatePicker x:Name="EndDatePicker" Width="130" Height="32"/>
                    <Button Content="Сформировать" Width="125" Height="34" Margin="16,0,6,0"
                            Background="#27AE60" Foreground="White" Click="OnGenerateClick"/>
                    <Button x:Name="ExportPdfButton" Content="Экспорт PDF" Width="110" Height="34"
                            Background="#34495E" Foreground="White" IsEnabled="False" Click="OnExportPdfClick"/>
                    <Button Content="Экспорт НДС XLS" Width="130" Height="34" Margin="6,0,0,0"
                            Background="#1F618D" Foreground="White" Click="OnExportVatClick"/>
                </WrapPanel>
                <WrapPanel x:Name="ReconciliationVariantPanel" Margin="0,10,0,0" Visibility="Collapsed">
                    <TextBlock Text="Вариант акта сверки:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="ReconciliationVariantCombo" Width="360" Height="32"
                              DisplayMemberPath="DisplayName"
                              ToolTip="FRX-варианты хранятся в метаданных и выбираются здесь, а не отдельными пунктами меню."/>
                    <TextBlock x:Name="ReconciliationVariantHint" Text="Варианты из метаданных Reports"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                </WrapPanel>
                <WrapPanel Margin="0,10,0,0">
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="SearchBox" Width="250" Height="32" Padding="8,4"
                             TextChanged="OnSearchChanged" ToolTip="Поиск по всем колонкам отчета"/>
                    <Button Content="Собрать период" Width="125" Height="34" Margin="16,0,6,0"
                            Background="#D68910" Foreground="White" Click="OnCollectPeriodClick"/>
                    <Button x:Name="PeriodStateButton" Content="Закрыть баланс" Width="150" Height="34"
                            Background="#C0392B" Foreground="White" Click="OnTogglePeriodClick"/>
                    <TextBlock x:Name="PeriodStatusText" Text="Период не собран" VerticalAlignment="Center"
                               Margin="16,0,0,0" FontWeight="SemiBold"/>
                </WrapPanel>
                <WrapPanel Margin="0,10,0,0">
                    <TextBlock Text="Рабочий модуль:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="PeriodModuleCombo" Width="260" Height="32"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="OnPeriodModuleSelectionChanged"/>
                    <Button x:Name="CloseModuleButton" Content="Закрыть модуль" Width="125" Height="34"
                            Margin="16,0,6,0" Background="#AF7AC5" Foreground="White"
                            Click="OnCloseModuleClick" IsEnabled="False"/>
                    <Button x:Name="ReopenModuleButton" Content="Открыть модуль" Width="125" Height="34"
                            Background="#5D6D7E" Foreground="White"
                            Click="OnReopenModuleClick" IsEnabled="False"/>
                    <TextBlock x:Name="PeriodModuleStatusText" Text="Модули периода недоступны"
                               VerticalAlignment="Center" Margin="16,0,0,0" FontWeight="SemiBold"/>
                </WrapPanel>
            </StackPanel>
        </Border>
        <DataGrid x:Name="ReportGrid" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False" FrozenColumnCount="2"
                  MouseDoubleClick="OnReportGridDoubleClick"/>

        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem><TextBlock x:Name="StatusText" Text="Выберите отчет и период"/></StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
