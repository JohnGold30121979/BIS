<Window x:Class="BIS.ERP.Views.PostingEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Проводка" Height="600" Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="DialogTitle" Grid.Row="0" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Статус -->
        <TextBlock x:Name="StatusText" Grid.Row="1" Foreground="Gray" FontSize="11" Margin="0,0,0,5"/>

        <!-- Поля с прокруткой -->
        <ScrollViewer Grid.Row="2" Grid.RowSpan="2" VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,10">
            <StackPanel x:Name="FieldsPanel" Margin="0,5,0,5"/>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Width="110" Height="36" Margin="0,0,10,0"
                    Click="OnSaveClick" Background="#27AE60" Foreground="White" FontWeight="Bold"/>
            <Button Content="Отмена" Width="110" Height="36" Click="OnCancelClick"
                    Background="#95A5A6" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
