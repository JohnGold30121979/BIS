<Window x:Class="BIS.ERP.Views.ModeSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BIS.ERP.Converters"
        Title="BIS ERP - Выбор режима работы"
        Height="550" Width="750"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Стиль для кнопок режимов -->
        <Style TargetType="Button" x:Key="ModeButton">
            <Setter Property="Height" Value="80"/>
            <Setter Property="Width" Value="280"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F4FD"/>
                                <Setter Property="BorderBrush" Value="#3498DB"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D1E7F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки выхода -->
        <Style TargetType="Button" x:Key="ExitButton">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FFF5F5"/>
            <Setter Property="Foreground" Value="#E74C3C"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#FEE2E2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="BorderBrush" Value="#E74C3C"/>
                                <Setter Property="Foreground" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Основной фон с тенью -->
    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.25" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Шапка с градиентом -->
            <Border Grid.Row="0" Background="#2C3E50" CornerRadius="20,20,0,0" Padding="30,25">
                <StackPanel>
                    <TextBlock Text="BIS ERP" FontSize="36" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center"
                               FontFamily="Segoe UI">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Выберите режим работы" FontSize="16" 
                               Foreground="#BDC3C7" HorizontalAlignment="Center" 
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Информация о пользователе -->
            <Border Grid.Row="1" Background="#F8F9FA" Margin="30,25,30,15" 
                    CornerRadius="12" Padding="20" BorderBrush="#E9ECEF" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Аватар -->
                    <Border Grid.Column="0" Width="60" Height="60" CornerRadius="30" 
                            Background="#3498DB" HorizontalAlignment="Left">
                        <TextBlock Text="👤" FontSize="32" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Информация -->
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#2C3E50">
                            <Run Text="{Binding UserFullName, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="#7F8C8D" Margin="0,5,0,0">
                            <Run Text="Логин: "/>
                            <Run Text="{Binding UserLogin, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                        <!-- Убрали конвертер, используем простой Border с фиксированным цветом -->
                        <Border Background="#3498DB" CornerRadius="10" Padding="8,3" 
                                HorizontalAlignment="Left" Margin="0,8,0,0">
                            <TextBlock FontSize="11" Foreground="White">
                                <Run Text="{Binding UserRoleText, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Кнопки режимов -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Margin="30,10,30,20">
                <!-- Рабочий режим -->
                <Button Style="{StaticResource ModeButton}" Command="{Binding SelectWorkModeCommand}">
                    <StackPanel>
                        <TextBlock Text="💼" FontSize="36" Margin="0,0,0,8"/>
                        <TextBlock Text="Рабочий режим" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Работа с документами и отчетами" FontSize="11" 
                                   Foreground="#7F8C8D" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Режим конфигуратора (виден только админу) -->
                <Button Style="{StaticResource ModeButton}" Command="{Binding SelectConfigModeCommand}" 
                        Visibility="{Binding IsAdminVisible, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <StackPanel>
                        <TextBlock Text="⚙️" FontSize="36" Margin="0,0,0,8"/>
                        <TextBlock Text="Режим конфигуратора" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Настройка метаданных и прав доступа" FontSize="11" 
                                   Foreground="#7F8C8D" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Кнопка выхода -->
            <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,0,0,35">
                <Button Style="{StaticResource ExitButton}" Command="{Binding CloseCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚪" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Выход из системы" FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
