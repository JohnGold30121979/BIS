<Window x:Class="BIS.ERP.Views.ConfiguratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIS ERP - Конфигуратор"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Главное меню -->
        <Menu Grid.Row="0" Background="#2C3E50" Foreground="White">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="Создать">
                <MenuItem Header="📚 Справочник" Click="OnCreateCatalogClick"/>               
                <MenuItem Header="📊 Отчет" Click="OnCreateReportClick"/>

                <!-- В раздел "Создать" меню добавьте: -->
                <MenuItem Header="Создать Динамически">
                    <MenuItem Header="📚 Справочник" Click="OnCreateDynamicCatalogClick"/>
                    <MenuItem Header="📄 Документ" Click="OnCreateDynamicDocumentClick"/>
                    <Separator/>
                    <MenuItem Header="📊 Отчет" Click="OnCreateReportClick"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Правка">             
               
                <Separator/>
                <MenuItem Header="📋 Копировать" IsEnabled="False"/>
                <MenuItem Header="✂️ Вырезать" IsEnabled="False"/>
                <MenuItem Header="📎 Вставить" IsEnabled="False"/>
            </MenuItem>
            
            <MenuItem Header="Справка">
                <MenuItem Header="📖 О программе" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0" Background="#2C3E50">
                <StackPanel>
                    <Border Background="#1A252F" Padding="15">
                        <StackPanel>
                            <TextBlock Text="BIS ERP" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Режим конфигуратора" FontSize="11" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>

                    <TreeView x:Name="MetadataTree" Background="#2C3E50" BorderThickness="0" 
                              Margin="0,10,0,0" MaxHeight="500">
                        <TreeView.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#34495E"/>
                        </TreeView.Resources>
                    </TreeView>

                    <StackPanel Margin="10" VerticalAlignment="Bottom">
                        <Button x:Name="AddCatalogButton" Content="➕ Справочник" 
                                Background="#27AE60" Foreground="White" Height="35" 
                                Click="OnCreateCatalogClick"/>
                        <Button x:Name="AddReportButton" Content="📊 Отчет" 
                                Background="#9B59B6" Foreground="White" Height="35" Margin="0,5,0,0"
                                Click="OnCreateReportClick"/>
                        <Button x:Name="ImportFrxButton" Content="📁 Импорт FRX" 
                                Background="#9B59B6" Foreground="White" Height="35" Margin="0,5,0,0"
                                Click="OnImportFrxClick"/>
                        <Button x:Name="RefreshButton" Content="🔄 Обновить" 
                                Background="#3498DB" Foreground="White" Height="35" Margin="0,10,0,0"
                                Click="OnRefreshClick"/>
                        
                        <!-- Добавьте в левую панель -->
                        <Button x:Name="SwitchModeButton" Click="OnSwitchModeClick" 
                            Background="#F39C12" Foreground="White" Height="35" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                                <TextBlock Text="Сменить режим" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImportDbfButton" Content="📁 Импорт из DBF" 
                                Background="#3498DB" Foreground="White" Height="35" Margin="0,5,0,0"
                                Click="OnImportDbfClick"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Правая панель -->
            <Border Grid.Column="1" Background="#F5F6FA">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock x:Name="EditorTitle" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                            <TextBlock x:Name="EditorDescription" Foreground="#666" FontSize="12" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1">
                        <Border Background="White" CornerRadius="8" Padding="20">
                            <StackPanel x:Name="PropertiesPanel">
                                <Border Background="#F8F9FA" CornerRadius="6" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="📌" FontSize="32" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Выберите объект метаданных слева" 
                                                   Foreground="#555" FontSize="13"
                                                   HorizontalAlignment="Center" Margin="0,10,0,5"/>
                                        <TextBlock Text="или нажмите 'Создать' для добавления нового" 
                                                   Foreground="#888" FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>