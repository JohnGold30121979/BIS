<Window x:Class="BIS.ERP.Views.ConfiguratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIS ERP - Конфигуратор"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Главное меню -->
        <Menu Grid.Row="0">
            <MenuItem Header="Файл">
                <MenuItem Header="Выгрузить конфигурацию..." Click="OnExportConfigurationClick"/>
                <MenuItem Header="Загрузить конфигурацию..." Click="OnImportConfigurationClick"/>
                <MenuItem Header="Анализ FoxPro-проекта..." Click="OnFoxProAnalysisClick"/>
                <MenuItem Header="Патчи инфобазы..." Click="OnPatchesClick"/>
                <MenuItem Header="Обновления программы..." Click="OnAppUpdatesClick"/>
                <MenuItem Header="Настройки системы..." Click="OnSettingsClick"/>
                <Separator/>
                <MenuItem Header="Выход" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="Создать">
                <MenuItem Header="Модуль" Click="OnModulesClick"/>
                <MenuItem Header="📚 Справочник" Click="OnCreateCatalogClick"/>               
                <MenuItem Header="📊 Отчет" Click="OnCreateReportClick"/>
                <MenuItem Header="Создать Динамически">
                    <MenuItem Header="📚 Справочник" Click="OnCreateDynamicCatalogClick"/>
                    <MenuItem Header="📄 Документ" Click="OnCreateDynamicDocumentClick"/>
                    <Separator/>
                    <MenuItem Header="📊 Отчет" Click="OnCreateReportClick"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="Правка">             
                <Separator/>
                <MenuItem Header="📋 Копировать" IsEnabled="False"/>
                <MenuItem Header="✂️ Вырезать" IsEnabled="False"/>
                <MenuItem Header="📎 Вставить" IsEnabled="False"/>
            </MenuItem>
            <MenuItem x:Name="DeleteReportMenuItem" Header="🗑️ Удалить отчет" 
                      IsEnabled="False" Click="OnDeleteReportClick"
                      InputGestureText="Del"/>
            <MenuItem Header="Справка">
                <MenuItem Header="📖 О программе" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" MinWidth="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0" Background="{DynamicResource ConfiguratorSidebarBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource ConfiguratorHeaderBackgroundBrush}" Padding="16">
                        <Border Background="{DynamicResource ConfiguratorSidebarCardBrush}"
                                CornerRadius="14" Padding="14" BorderThickness="1"
                                BorderBrush="{DynamicResource AppBorderBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="12"
                                        Background="{DynamicResource ConfiguratorTreeItemSelectedBrush}"
                                        VerticalAlignment="Top" Margin="0,0,12,0">
                                    <TextBlock x:Name="SystemIconText" FontSize="22"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="White"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="SystemNameText" FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource ConfiguratorTreeItemForegroundBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="Режим конфигуратора" FontSize="11"
                                               Foreground="{DynamicResource ConfiguratorTreeGroupForegroundBrush}"
                                               Margin="0,2,0,8"/>
                                    <Border Background="{DynamicResource ConfiguratorPatchBadgeBackgroundBrush}"
                                            CornerRadius="10" Padding="8,3" HorizontalAlignment="Left">
                                        <TextBlock x:Name="PatchVersionText" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ConfiguratorPatchBadgeForegroundBrush}"
                                                   Text="Патч: -"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Border>

                    <ScrollViewer x:Name="LeftNavigationScrollViewer" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="OnLeftNavigationPreviewMouseWheel">
                        <StackPanel>
                            <TreeView x:Name="MetadataTree" Background="{DynamicResource ConfiguratorSidebarBackgroundBrush}"
                                      Foreground="{DynamicResource ConfiguratorTreeItemForegroundBrush}" BorderThickness="0"
                                      Margin="10,12,10,0" Padding="0,2"
                                      SelectedItemChanged="OnTreeSelectedChanged"
                                      MouseRightButtonUp="OnTreeRightClick"
                                      PreviewMouseWheel="OnLeftNavigationPreviewMouseWheel">
                                <TreeView.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2F80C9"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#2F80C9"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
                                    <Style TargetType="{x:Type TreeViewItem}">
                                        <Setter Property="Foreground" Value="{DynamicResource ConfiguratorTreeItemForegroundBrush}"/>
                                        <Setter Property="FontSize" Value="13"/>
                                        <Setter Property="Padding" Value="8,7"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type TreeViewItem}">
                                                    <StackPanel>
                                                        <Border x:Name="ItemBorder" Background="Transparent"
                                                                CornerRadius="9" Padding="{TemplateBinding Padding}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="18"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ToggleButton x:Name="Expander" Width="16" Height="16"
                                                                              VerticalAlignment="Center"
                                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                              ClickMode="Press"
                                                                              Background="Transparent" BorderThickness="0"
                                                                              Foreground="{TemplateBinding Foreground}">
                                                                    <TextBlock x:Name="ExpanderGlyph" Text="›"
                                                                               FontSize="16" FontWeight="Bold"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                </ToggleButton>
                                                                <ContentPresenter Grid.Column="1" x:Name="PART_Header"
                                                                                  ContentSource="Header"
                                                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                  VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                        <ItemsPresenter x:Name="ItemsHost" Margin="20,2,0,0"/>
                                                    </StackPanel>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="HasItems" Value="False">
                                                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                        </Trigger>
                                                        <Trigger Property="IsExpanded" Value="False">
                                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                        <Trigger Property="IsExpanded" Value="True">
                                                            <Setter TargetName="ExpanderGlyph" Property="Text" Value="⌄"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ConfiguratorTreeItemHoverBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ConfiguratorTreeItemSelectedBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </Trigger>
                                                        <MultiTrigger>
                                                            <MultiTrigger.Conditions>
                                                                <Condition Property="IsSelected" Value="True"/>
                                                                <Condition Property="IsSelectionActive" Value="False"/>
                                                            </MultiTrigger.Conditions>
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ConfiguratorTreeItemSelectedBrush}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </MultiTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                    <ContextMenu x:Key="ReportContextMenu">
                                        <MenuItem Header="📊 Открыть в конструкторе" Click="OnOpenReportDesignerClick"/>
                                        <Separator/>
                                        <MenuItem Header="📋 Сделать доступным / отключить" Click="OnToggleReportAvailabilityClick"/>
                                        <Separator/>
                                        <MenuItem Header="💻 Предпросмотр в окне" Click="OnPreviewReportClick"/>
                                        <Separator/>
                                        <MenuItem Header="🗑️ Удалить отчет" Click="OnDeleteReportClick" Foreground="#E74C3C"/>
                                    </ContextMenu>
                                </TreeView.Resources>
                            </TreeView>

                            <StackPanel Margin="10">
                                <Button x:Name="AddCatalogButton" Content="➕ Справочник"
                                        Background="#27AE60" Foreground="White" Height="35"
                                        Click="OnCreateCatalogClick"/>
                                <Button Content="Модули и разделы" Background="#2980B9" Foreground="White"
                                        Height="35" Margin="0,5,0,0" Click="OnModulesClick"/>
                                <Button x:Name="AccountingSetupButton" Content="⚙ Настройка учета"
                                        Background="#1F618D" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnAccountingSetupClick"/>
                                <Button x:Name="AddReportButton" Content="📊 Отчет"
                                        Background="#9B59B6" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnCreateReportClick"/>
                                <Button x:Name="ImportFrxButton" Content="📁 Импорт FRX"
                                        Background="#9B59B6" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnImportFrxClick"/>
                                <Button x:Name="RegulatedTemplatesButton" Content="🧾 Шаблоны отчетов"
                                        Background="#7D3C98" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnRegulatedTemplatesClick"/>
                                <Button x:Name="ExportConfigurationButton" Content="⬆ Выгрузить конфигурацию"
                                        Background="#16A085" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnExportConfigurationClick"/>
                                <Button x:Name="ImportConfigurationButton" Content="⬇ Загрузить конфигурацию"
                                        Background="#D68910" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnImportConfigurationClick"/>
                                <Button x:Name="PatchesButton" Content="🧩 Патчи инфобазы"
                                        Background="#2C3E50" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnPatchesClick"/>
                                <Button x:Name="AppUpdatesButton" Content="🚀 Обновления программы"
                                        Background="#34495E" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnAppUpdatesClick"/>
                                <Button x:Name="RefreshButton" Content="🔄 Обновить"
                                        Background="#3498DB" Foreground="White" Height="35" Margin="0,10,0,0"
                                        Click="OnRefreshClick"/>
                                <Button x:Name="SwitchModeButton" Click="OnSwitchModeClick"
                                    Background="#F39C12" Foreground="White" Height="35" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="🔄" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="Сменить режим" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ImportDbfButton" Content="📁 Импорт из DBF"
                                        Background="#3498DB" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnImportDbfClick"/>
                                <Button x:Name="FoxProAnalysisButton" Content="Анализ FoxPro"
                                        Background="#1F618D" Foreground="White" Height="35" Margin="0,5,0,0"
                                        Click="OnFoxProAnalysisClick"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Сплиттер -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#34495E" ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"/>

            <!-- Правая панель -->
            <Border Grid.Column="2" Background="{DynamicResource AppContentBackgroundBrush}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock x:Name="EditorTitle" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                            <TextBlock x:Name="EditorDescription" Foreground="#666" FontSize="12" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="PropertiesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Background="White" CornerRadius="8" Padding="20">
                            <StackPanel x:Name="PropertiesPanel">
                                <Border Background="#F8F9FA" CornerRadius="6" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="📌" FontSize="32" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Выберите объект метаданных слева" 
                                                   Foreground="#555" FontSize="13"
                                                   HorizontalAlignment="Center" Margin="0,10,0,5"/>
                                        <TextBlock Text="или нажмите 'Создать' для добавления нового" 
                                                   Foreground="#888" FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
