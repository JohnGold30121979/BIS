<UserControl x:Class="BIS.ERP.Views.Configurator.ModuleManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
        <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1" CornerRadius="7" Padding="10">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="Модули" FontSize="16" FontWeight="SemiBold" Margin="4,2,0,10"/>
                <ListBox x:Name="ModulesList" Grid.Row="1" DisplayMemberPath="Name" SelectionChanged="OnModuleSelected"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Добавить" Width="105" Height="34" Click="OnAddClick"
                            Background="#27AE60" Foreground="White"/>
                    <Button x:Name="DeleteButton" Content="Удалить" Width="95" Height="34" Margin="8,0,0,0"
                            Click="OnDeleteClick" Background="#C0392B" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1" CornerRadius="7" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="14"/><ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Наименование" Margin="0,0,0,5"/>
                        <TextBox x:Name="NameBox" Height="35" Padding="8,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Код" Margin="0,0,0,5"/>
                        <TextBox x:Name="CodeBox" Height="35" Padding="8,4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Иконка" Margin="0,0,0,5"/>
                        <TextBox x:Name="IconBox" Height="35" Padding="8,4"/>
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" Margin="0,12,0,14">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="110"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Описание" Margin="0,0,0,5"/>
                        <TextBox x:Name="DescriptionBox" Height="58" Padding="8" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Порядок" Margin="0,0,0,5"/>
                        <TextBox x:Name="OrderBox" Height="35" Padding="8,4"/>
                    </StackPanel>
                    <CheckBox x:Name="IsActiveCheck" Grid.Column="2" Content="Доступен в инфобазе"
                              VerticalAlignment="Center" Margin="15,15,0,0" IsChecked="True"/>
                </Grid>

                <Grid Grid.Row="2" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Порядок закрытия" Margin="0,0,0,5"/>
                        <TextBox x:Name="CloseOrderBox" Height="35" Padding="8,4"/>
                    </StackPanel>
                    <CheckBox x:Name="ParticipatesInPeriodCloseCheck" Grid.Column="3"
                              Content="Участвует в закрытии периода"
                              VerticalAlignment="Center" Margin="0,18,0,0" IsChecked="True"/>
                    <CheckBox x:Name="RequirePreviousModulesClosedCheck" Grid.Column="5"
                              Content="Закрывать только после предыдущих модулей"
                              VerticalAlignment="Center" Margin="0,18,0,0"/>
                </Grid>

                <TabControl Grid.Row="3">
                    <TabItem Header="Документы">
                        <DataGrid x:Name="DocumentsGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="В модуле" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                                <DataGridTextColumn Header="Документ" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Отчеты">
                        <DataGrid x:Name="ReportsGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="В модуле" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="85"/>
                                <DataGridTextColumn Header="Отчет" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>

                <Grid Grid.Row="4" Margin="0,14,0,0">
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                    <Button Content="Сохранить модуль" Width="150" Height="38" HorizontalAlignment="Right"
                            Click="OnSaveClick" Background="{DynamicResource AppAccentBrush}" Foreground="White"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
