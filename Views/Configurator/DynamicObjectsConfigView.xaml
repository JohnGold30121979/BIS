<UserControl x:Class="BIS.ERP.Configurator.Views.DynamicObjectsConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,10,0">
            <StackPanel>
                <Button Content="➕ Новый объект" Click="OnCreateObjectClick" 
                        Background="#4CAF50" Foreground="White" Padding="10" Margin="0,0,0,10"/>
                <TextBlock Text="Объекты метаданных" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListBox x:Name="ObjectsList" SelectionChanged="OnObjectSelected" Height="400">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding ObjectType}" FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Правая панель -->
        <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="10">
            <ScrollViewer>
                <StackPanel x:Name="EditorPanel">
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Наименование" FontWeight="Bold"/>
                    <TextBox x:Name="txtName" Margin="0,5,0,15"/>

                    <TextBlock Text="Тип объекта" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbType" Margin="0,5,0,15">
                        <ComboBoxItem Content="Справочник" Tag="Catalog"/>
                        <ComboBoxItem Content="Документ" Tag="Document"/>
                    </ComboBox>

                    <TextBlock Text="Иконка" FontWeight="Bold"/>
                    <TextBox x:Name="txtIcon" Margin="0,5,0,15"/>

                    <TextBlock Text="Описание" FontWeight="Bold"/>
                    <TextBox x:Name="txtDescription" TextWrapping="Wrap" Height="60" Margin="0,5,0,15"/>

                    <CheckBox x:Name="chkPostings" Content="Использует проводки" Margin="0,5"/>
                    <CheckBox x:Name="chkBalances" Content="Использует балансы" Margin="0,5"/>

                    <TextBlock Text="Поля" FontWeight="Bold" Margin="0,15,0,5"/>
                    <Button Content="➕ Добавить поле" Click="OnAddFieldClick" Margin="0,0,0,5"/>
                    <DataGrid x:Name="FieldsGrid" AutoGenerateColumns="True" Height="150" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="💾 Сохранить" Click="OnSaveClick" Background="#4CAF50" Foreground="White" Padding="15,8" Margin="5"/>
                        <Button Content="🗑️ Удалить" Click="OnDeleteClick" Background="#F44336" Foreground="White" Padding="15,8" Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>