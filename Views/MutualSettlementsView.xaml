<UserControl x:Class="BIS.ERP.Views.MutualSettlementsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Период -->
        <GroupBox Header="Период" Grid.Row="0" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Начало:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker x:Name="dpStartDate" SelectedDate="{Binding StartDate}" Width="120" Margin="0,0,10,0"/>
                <TextBlock Text="Конец:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker x:Name="dpEndDate" SelectedDate="{Binding EndDate}" Width="120" Margin="0,0,10,0"/>
                <Button x:Name="btnRefresh" Content="Обновить" Click="btnRefresh_Click" Width="100" Margin="5,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Инструменты -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <Button x:Name="btnAllOrgs" Content="Все организации" Click="btnViewMode_Click" Tag="All" Width="140" Margin="0,0,5,0" Background="#2196F3" Foreground="White"/>
            <Button x:Name="btnDebtors" Content="Дебиторы" Click="btnViewMode_Click" Tag="Debtors" Width="100" Margin="0,0,5,0" Background="#4CAF50" Foreground="White"/>
            <Button x:Name="btnCreditors" Content="Кредиторы" Click="btnViewMode_Click" Tag="Creditors" Width="100" Margin="0,0,5,0" Background="#FF9800" Foreground="White"/>
            <Separator Width="2" Margin="5,0"/>
            <Button x:Name="btnExpand" Content="Развернуть" Click="btnExpand_Click" Width="100" Margin="0,0,5,0"/>
            <Button x:Name="btnCollapse" Content="Свернуть" Click="btnCollapse_Click" Width="100" Margin="0,0,5,0"/>
            <Separator Width="2" Margin="5,0"/>
            <Button x:Name="btnReconciliation" Content="Акт сверки" Click="btnReconciliation_Click" Width="100" Margin="0,0,5,0"/>
            <Button x:Name="btnFilter" Content="Фильтр по счету" Click="btnFilter_Click" Width="130" Margin="0,0,5,0"/>
            <Button x:Name="btnPrint" Content="Печать" Click="btnPrint_Click" Width="80"/>
            <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#5D6D7E" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Фильтр по счету -->
        <GroupBox x:Name="grpFilter" Header="Фильтр по паре счетов" Grid.Row="2" Margin="0,5" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Margin="5">
                <ComboBox x:Name="cmbAccountPair" Width="300" DisplayMemberPath="name" SelectedValuePath="Id" Margin="0,0,10,0"/>
                <Button Content="Установить фильтр" Click="btnSetFilter_Click" Width="130" Margin="0,0,5,0"/>
                <Button Content="Отказ от фильтра" Click="btnClearFilter_Click" Width="130"/>
            </StackPanel>
        </GroupBox>

        <!-- Данные -->
        <DataGrid x:Name="dgSettlements" Grid.Row="3" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" RowHeaderWidth="0"
                  Margin="0,5,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Организация" Binding="{Binding organization_name}" Width="180"/>
                <DataGridTextColumn Header="Вид расчета" Binding="{Binding account_pair_name}" Width="220"/>
                <DataGridTextColumn Header="Дебет" Binding="{Binding debit_account}" Width="95"/>
                <DataGridTextColumn Header="Кредит" Binding="{Binding credit_account}" Width="95"/>
                <DataGridTextColumn Header="Сальдо нач. Дт" Binding="{Binding opening_debit, StringFormat=N2}" Width="115"/>
                <DataGridTextColumn Header="Сальдо нач. Кт" Binding="{Binding opening_credit, StringFormat=N2}" Width="115"/>
                <DataGridTextColumn Header="Оборот Дт" Binding="{Binding debit_total, StringFormat=N2}" Width="105"/>
                <DataGridTextColumn Header="Оборот Кт" Binding="{Binding credit_total, StringFormat=N2}" Width="105"/>
                <DataGridTextColumn Header="Сальдо кон. Дт" Binding="{Binding closing_debit, StringFormat=N2}" Width="115"/>
                <DataGridTextColumn Header="Сальдо кон. Кт" Binding="{Binding closing_credit, StringFormat=N2}" Width="115"/>
                <DataGridTextColumn Header="Сальдо" Binding="{Binding balance, StringFormat=N2}" Width="105"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
