<UserControl x:Class="BIS.ERP.Views.PostingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="ПРОВОДКИ" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock Text="Журнал бухгалтерских проводок" FontSize="12" Foreground="Gray"/>
        </StackPanel>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="AddButton" Content="📝 Ввод новой проводки (F2)" Width="180" Height="35" Margin="0,0,10,0"
                    Background="#27AE60" Foreground="White" Click="OnAddClick"/>
            <Button x:Name="EditButton" Content="✏️ Корректировка (F3)" Width="160" Height="35" Margin="0,0,10,0"
                    Background="#3498DB" Foreground="White" IsEnabled="False" Click="OnEditClick"/>
            <Button x:Name="DeleteButton" Content="🗑️ Удалить (Del)" Width="140" Height="35" Margin="0,0,10,0"
                    Background="#E74C3C" Foreground="White" IsEnabled="False" Click="OnDeleteClick"/>
            <Button x:Name="RefreshButton" Content="🔄 Обновить" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#95A5A6" Foreground="White" Click="OnRefreshClick"/>
            <Button x:Name="SearchButton" Content="🔍 Поиск" Width="100" Height="35"
                    Background="#F39C12" Foreground="White" Click="OnSearchClick"/>
        </StackPanel>

        <!-- Таблица проводок -->
        <DataGrid x:Name="PostingsGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionChanged="PostingsGrid_SelectionChanged"
                  AlternatingRowBackground="#F5F5F5" BorderBrush="#BDC3C7" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding Дата}" Width="100"/>
                <DataGridTextColumn Header="Номер документа" Binding="{Binding Номер документа}" Width="120"/>
                <DataGridTextColumn Header="Дебет" Binding="{Binding Дебет}" Width="200"/>
                <DataGridTextColumn Header="Кредит" Binding="{Binding Кредит}" Width="200"/>
                <DataGridTextColumn Header="Сумма в сом" Binding="{Binding Сумма в сом}" Width="120"/>
                <DataGridTextColumn Header="Сумма в валюте" Binding="{Binding Сумма в валюте}" Width="120"/>
                <DataGridTextColumn Header="Валюта" Binding="{Binding Валюта}" Width="80"/>
                <DataGridTextColumn Header="Организация" Binding="{Binding Организация}" Width="150"/>
                <DataGridTextColumn Header="Примечание" Binding="{Binding Примечание}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готово" Foreground="Gray"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="ProgressText" Text="" Foreground="Blue"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>