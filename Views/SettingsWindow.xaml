<Window x:Class="BIS.ERP.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки приложения" Height="760" Width="640"
        MinHeight="620" MinWidth="560" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Настройки приложения" FontSize="23" FontWeight="Bold"
                       Foreground="{DynamicResource AppBodyTextBrush}"/>
            <TextBlock Text="Оформление и сведения, отображаемые в разделе «Справка»"
                       Foreground="{DynamicResource AppSecondaryTextBrush}" Margin="0,5,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="7" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Сведения о системе" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,14"/>
                        <TextBlock Text="Наименование системы" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="SystemNameBox" Height="36" Padding="8,5" Margin="0,0,8,0"/>
                            <TextBox x:Name="SystemIconBox" Grid.Column="1" Height="36" Padding="8,5"
                                     TextChanged="OnSystemIconTextChanged"
                                     ToolTip="Иконка рядом с названием"/>
                        </Grid>
                        <TextBlock Text="Логотип системы" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="10"
                                    Background="{DynamicResource AppReadOnlyBackgroundBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Image x:Name="SystemLogoPreviewImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                                    <TextBlock x:Name="SystemLogoPlaceholderText" Text="🏢" FontSize="24"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock x:Name="SystemLogoNameText" Text="Логотип не загружен"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="LoadSystemLogoButton" Content="Загрузить PNG/ICO" Width="145" Height="32"
                                            Background="{DynamicResource AppAccentBrush}" Foreground="White"
                                            Click="OnLoadSystemLogoClick"/>
                                    <Button x:Name="ClearSystemLogoButton" Content="Убрать" Width="80" Height="32" Margin="8,0,0,0"
                                            Background="{DynamicResource AppReadOnlyBackgroundBrush}"
                                            Foreground="{DynamicResource AppBodyTextBrush}"
                                            Click="OnClearSystemLogoClick"/>
                                </StackPanel>
                                <TextBlock x:Name="SystemLogoRestrictionText"
                                           Text="Загрузка логотипа доступна только администратору через конфигуратор."
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Описание" Margin="0,0,0,5"/>
                        <TextBox x:Name="DescriptionBox" MinHeight="64" Padding="8" TextWrapping="Wrap"
                                 AcceptsReturn="True" Margin="0,0,0,12"/>
                        <TextBlock Text="Реквизиты компании" Margin="0,0,0,5"/>
                        <TextBox x:Name="CompanyDetailsBox" MinHeight="82" Padding="8" TextWrapping="Wrap"
                                 AcceptsReturn="True" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Электронная почта" Margin="0,0,0,5"/>
                                <TextBox x:Name="EmailBox" Height="36" Padding="8,5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Телефон" Margin="0,0,0,5"/>
                                <TextBox x:Name="PhoneBox" Height="36" Padding="8,5"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Ссылка проверки обновлений программы" Margin="0,14,0,5"/>
                        <TextBox x:Name="AppUpdateUrlBox" Height="36" Padding="8,5"
                                 ToolTip="Можно указать URL на update.json или прямую ссылку на .bisapp"/>
                        <TextBlock Text="Поддерживается прямая ссылка на .bisapp или JSON-фид с PackageUrl."
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="7" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Интерфейс" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,14"/>
                        <TextBlock Text="Тема оформления" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ThemeComboBox" Height="36" SelectedValuePath="Tag"
                                  SelectionChanged="OnThemeChanged" Margin="0,0,0,5">
                            <ComboBoxItem Content="Светлая" Tag="Default"/>
                            <ComboBoxItem Content="Темная" Tag="Dark"/>
                            <ComboBoxItem Content="Dracula" Tag="Dracula"/>
                        </ComboBox>
                        <TextBlock x:Name="CurrentThemeText" Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   FontSize="11" Margin="0,0,0,12"/>
                        <TextBlock Text="Язык интерфейса" Margin="0,0,0,5"/>
                        <ComboBox x:Name="LanguageComboBox" Height="36" SelectedValuePath="Tag"
                                  SelectionChanged="OnLanguageChanged">
                            <ComboBoxItem Content="Русский" Tag="ru-RU"/>
                            <ComboBoxItem Content="English" Tag="en-US"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="7" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Обслуживание справочников" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="Загрузка официальных курсов валют из XML-сервисов Национального банка Кыргызской Республики."
                                   Foreground="{DynamicResource AppSecondaryTextBrush}" TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="LoadNationalBankRatesButton"
                                    Content="Загрузить курсы НБКР"
                                    Width="175" Height="36"
                                    Background="{DynamicResource AppAccentBrush}"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    Click="OnLoadNationalBankRatesClick"/>
                            <TextBlock x:Name="NationalBankRatesStatusText"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Отмена" Width="105" Height="38" Margin="0,0,10,0"
                    Background="{DynamicResource AppReadOnlyBackgroundBrush}"
                    Foreground="{DynamicResource AppBodyTextBrush}" IsCancel="True"/>
            <Button Content="Сохранить" Width="120" Height="38"
                    Background="{DynamicResource AppAccentBrush}" Foreground="White"
                    FontWeight="SemiBold" Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
