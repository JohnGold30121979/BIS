<UserControl x:Class="BIS.ERP.Views.CatalogDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопки -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TitleText" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock x:Name="DescriptionText" Foreground="#666" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="EditButton" Content="✏️ Редактировать" 
                            Width="110" Height="35" Margin="0,0,10,0"
                            Background="#3498DB" Foreground="White" Click="OnEditClick"
                            IsEnabled="False"/>
                    <Button x:Name="DeleteButton" Content="🗑️ Удалить" 
                            Width="90" Height="35" Margin="0,0,10,0"
                            Background="#E74C3C" Foreground="White" Click="OnDeleteClick"
                            IsEnabled="False"/>
                    <Button x:Name="ExportButton" Content="📎 Экспорт" 
                            Width="90" Height="35" Margin="0,0,10,0"
                            Background="#9B59B6" Foreground="White" Click="OnExportClick"/>
                    <Button x:Name="ImportDbfButton" Content="📥 Загрузить DBF"
                            Width="130" Height="35" Margin="0,0,10,0"
                            Background="#16A085" Foreground="White" Click="OnImportDbfClick"
                            Visibility="Collapsed"/>
                    <Button x:Name="AddButton" Content="➕ Добавить" 
                            Width="100" Height="35" Margin="0,0,10,0"
                            Background="#27AE60" Foreground="White" Click="OnAddClick"/>
                    <Button x:Name="RefreshButton" Content="🔄 Обновить" 
                            Width="90" Height="35"
                            Background="#3498DB" Foreground="White" Click="OnRefreshClick"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Поиск по счетам -->
        <Border x:Name="SearchPanel" Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" Grid.Column="0"
                         Height="35" Padding="10,6"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"
                         ToolTip="Поиск по коду и наименованию счета"/>

                <Button x:Name="SearchButton" Grid.Column="1" Content="🔍 Поиск"
                        Width="100" Height="35" Margin="10,0,0,0"
                        Background="#3498DB" Foreground="White"
                        Click="SearchButton_Click"/>
            </Grid>
        </Border>

        <!-- Таблица данных -->
        <DataGrid x:Name="DataGrid" Grid.Row="2" 
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F8F9FA"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="0"
                  RowHeight="35"
                  ColumnHeaderHeight="52"
                  FontSize="13"
                  SelectionChanged="DataGrid_SelectionChanged">
            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3498DB" Opacity="0.3"/>
            </DataGrid.Resources>
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="4,6"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!-- Статус бар -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="15" Margin="0,20,0,0">
            <Grid>
                <TextBlock x:Name="StatusText" Text="Готово" Foreground="#666" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="ProgressText" Text="" Foreground="#3498DB" FontSize="12" 
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
