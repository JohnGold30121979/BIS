<Window x:Class="BIS.ERP.Views.InfoBaseSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор информационной базы"
        Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="White" CornerRadius="10" Padding="20">
        <StackPanel>
            <!-- Заголовок -->
            <TextBlock Text="📊 Выбор информационной базы" FontSize="20" FontWeight="Bold" 
                       Foreground="#2C3E50" Margin="0,0,0,10"/>
            <TextBlock Text="Выберите базу данных для работы" Foreground="#7F8C8D" 
                       Margin="0,0,0,20"/>

            <!-- Список баз -->
            <TextBlock Text="Доступные базы:" FontWeight="Bold" Margin="0,0,0,8"/>
            <ListBox x:Name="InfoBasesList" Height="250" Margin="0,0,0,15"
                     SelectionChanged="OnSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" Margin="0,2" CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="20" Margin="0,0,10,0"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding TypeName}" Foreground="#666" FontSize="11"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat=Создана: dd.MM.yyyy}" 
                                               Foreground="#999" FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E8F4FD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="CreateButton" Content="➕ Создать новую" 
                        Width="120" Height="35" Margin="0,0,10,0"
                        Background="#3498DB" Foreground="White"
                        Click="OnCreateClick"/>
                <Button x:Name="SelectButton" Content="✅ Выбрать" 
                        Width="100" Height="35" Margin="0,0,10,0"
                        Background="#27AE60" Foreground="White"
                        IsEnabled="False" Click="OnSelectClick"/>
                <Button x:Name="CancelButton" Content="Отмена" 
                        Width="80" Height="35"
                        Background="#95A5A6" Foreground="White"
                        Click="OnCancelClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>