<Window x:Class="BIS.ERP.Views.CreateCatalogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание справочника"
        Height="650" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="500"
        ShowInTaskbar="False">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Прокручиваемая область -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel>
                <TextBlock Text="➕ Создание нового справочника" FontSize="20" FontWeight="Bold" 
                           Margin="0,0,0,20" Foreground="#2C3E50"/>

                <!-- Наименование -->
                <TextBlock Text="Наименование справочника" Foreground="#333" Margin="0,0,0,5"/>
                <TextBox x:Name="NameBox" Height="35" Padding="10" Margin="0,0,0,15"/>

                <!-- Описание -->
                <TextBlock Text="Описание" Foreground="#333" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionBox" Height="60" Padding="10" 
                         TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

                <!-- Иконка -->
                <TextBlock Text="Иконка" Foreground="#333" Margin="0,0,0,5"/>
                <ComboBox x:Name="IconCombo" Height="35" Margin="0,0,0,15" SelectedIndex="0">
                    <ComboBoxItem>👥 Сотрудники</ComboBoxItem>
                    <ComboBoxItem>📦 Материалы</ComboBoxItem>
                    <ComboBoxItem>⚙️ Основные средства</ComboBoxItem>
                    <ComboBoxItem>🏢 Подразделения</ComboBoxItem>
                    <ComboBoxItem>💰 Финансы</ComboBoxItem>
                    <ComboBoxItem>🚗 Транспорт</ComboBoxItem>
                    <ComboBoxItem>📚 Документы</ComboBoxItem>
                </ComboBox>

                <!-- Поля справочника -->
                <TextBlock Text="Реквизиты справочника" FontSize="14" FontWeight="Bold" 
                           Margin="0,15,0,10"/>

                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="5" Padding="5">
                    <ItemsControl x:Name="FieldsList" MaxHeight="180">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" Background="#F8F9FA" CornerRadius="5" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                 Grid.Column="0" Margin="0,0,5,0" Height="30" Padding="5,0"/>

                                        <ComboBox SelectedItem="{Binding Type}" Grid.Column="1" Height="30" Margin="5,0">
                                            <ComboBoxItem>String</ComboBoxItem>
                                            <ComboBoxItem>Int</ComboBoxItem>
                                            <ComboBoxItem>Decimal</ComboBoxItem>
                                            <ComboBoxItem>DateTime</ComboBoxItem>
                                            <ComboBoxItem>Bool</ComboBoxItem>
                                        </ComboBox>

                                        <CheckBox IsChecked="{Binding IsRequired}" Content="Обязат." Grid.Column="2" 
                                                  VerticalAlignment="Center" Margin="5,0"/>

                                        <Button Content="❌" Grid.Column="3" Width="30" Height="30"
                                                Background="Transparent" Click="RemoveField_Click"
                                                Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <Button x:Name="AddFieldButton" Content="+ Добавить реквизит" 
                        Background="#3498DB" Foreground="White" Height="35" Margin="0,10"
                        Click="OnAddFieldClick" Cursor="Hand"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <Border Grid.Row="1" Background="White" Padding="20,10,20,20" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="📁 Загрузить из JSON" Click="OnLoadFromJsonClick" 
                        Margin="0,0,10,0" Background="#9B59B6" Foreground="White"/>
                <Button x:Name="CreateButton" Content="Создать" Width="110" Height="36"
                        Margin="0,0,10,0" Background="#27AE60" Foreground="White" Click="OnCreateClick" Cursor="Hand"/>
                <Button x:Name="CancelButton" Content="Отмена" Width="110" Height="36"
                        Click="OnCancelClick" Background="#95A5A6" Foreground="White" Cursor="Hand"/>
                
            </StackPanel>
        </Border>
    </Grid>
</Window>
