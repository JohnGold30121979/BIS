<Window x:Class="BIS.ERP.Views.ReportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Предпросмотр отчета"
        Height="800" Width="1100"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PrintButton" Content="🖨️ Печать" Width="100" Height="35" Margin="5"
                        Background="#3498DB" Foreground="White" Click="OnPrintClick"/>
                <Button x:Name="ExportExcelButton" Content="📎 Excel" Width="100" Height="35" Margin="5"
                        Background="#27AE60" Foreground="White" Click="OnExportExcelClick"/>
                <Button x:Name="ExportHtmlButton" Content="🌐 HTML" Width="100" Height="35" Margin="5"
                        Background="#9B59B6" Foreground="White" Click="OnExportHtmlClick"/>
                <Button x:Name="CloseButton" Content="✖ Закрыть" Width="100" Height="35" Margin="5"
                        Background="#E74C3C" Foreground="White" Click="OnCloseClick"/>

                <Separator Width="20" Opacity="0"/>

                <TextBlock x:Name="PageInfoText" Foreground="White" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Область предпросмотра с прокруткой -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="#F5F6FA">
            <Border x:Name="ReportContainer" Background="White" Margin="20" Padding="20"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <!-- Шапка отчета -->
                    <Border x:Name="HeaderPanel" Background="#2C3E50" Padding="15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock x:Name="HeaderTitle" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="HeaderSubtitle" FontSize="12" Foreground="#BDC3C7" Margin="0,5,0,0"/>
                            <Border Height="2" Background="#3498DB" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Таблица данных -->
                    <DataGrid x:Name="PreviewGrid" AutoGenerateColumns="True"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" RowHeaderWidth="0"
                              BorderThickness="0" Margin="0,0,0,20"/>

                    <!-- Подвал отчета -->
                    <Border x:Name="FooterPanel" Background="#F8F9FA" Padding="15" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock x:Name="FooterText" FontSize="11" Foreground="#666" TextWrapping="Wrap"/>
                            <Border Height="1" Background="#E0E0E0" Margin="0,10,0,10"/>
                            <Grid>
                                <TextBlock x:Name="FooterTotal" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="PageNumber" FontSize="11" Foreground="#666" HorizontalAlignment="Right"/>
                            </Grid>
                            <TextBlock x:Name="FooterSignature" FontSize="11" Foreground="#666" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="#2C3E50" Padding="10">
            <TextBlock x:Name="StatusText" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>