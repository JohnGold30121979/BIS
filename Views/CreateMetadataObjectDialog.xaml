<Window x:Class="BIS.ERP.Views.CreateMetadataObjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание объекта метаданных"
        Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="White" CornerRadius="10" Padding="20">
        <StackPanel>
            <TextBlock Text="➕ Создание объекта метаданных" FontSize="18" FontWeight="Bold" 
                       Margin="0,0,0,20" Foreground="#2C3E50"/>

            <TextBlock Text="Имя объекта" Foreground="#333" Margin="0,0,0,5"/>
            <TextBox x:Name="NameBox" Height="35" Padding="10" Margin="0,0,0,15"/>

            <TextBlock Text="Тип объекта" Foreground="#333" Margin="0,0,0,5"/>
            <ComboBox x:Name="TypeCombo" Height="35" Margin="0,0,0,15" SelectedIndex="0">
                <ComboBoxItem Content="📚 Справочник" Tag="Catalog"/>
                <ComboBoxItem Content="📄 Документ" Tag="Document"/>
                <ComboBoxItem Content="📊 Отчет" Tag="Report"/>
            </ComboBox>

            <TextBlock Text="Раздел" Foreground="#333" Margin="0,0,0,5"/>
            <ComboBox x:Name="ParentCombo" Height="35" Margin="0,0,0,25"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="Отмена" Width="90" Height="35" 
                        Margin="0,0,10,0" Click="OnCancelClick"/>
                <Button x:Name="CreateButton" Content="Создать" Width="90" Height="35" 
                        Background="#27AE60" Foreground="White" Click="OnCreateClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>