<UserControl x:Class="BIS.ERP.Views.UserAccessManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppContentBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="Пользователи и права доступа" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Выберите пользователя и отметьте доступные ему разделы рабочего окна."
                       Foreground="{DynamicResource AppSecondaryTextBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions>
            <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="7" Padding="12">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="Пользователи информационной базы" FontWeight="SemiBold" Margin="3,0,0,10"/>
                    <DataGrid x:Name="UsersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" SelectionChanged="OnUserSelected">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="110"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding RoleDisplay}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="7" Padding="14">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock x:Name="SelectedUserText" Text="Выберите пользователя" FontWeight="SemiBold" Margin="2,0,0,10"/>
                    <TreeView x:Name="AccessTree" Grid.Row="1" ItemsSource="{Binding Capabilities}"
                              Background="Transparent" BorderThickness="0">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="True"/>
                                <Setter Property="Padding" Value="3"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          IsThreeState="True" Padding="3"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="SelectAllButton" Content="Разрешить все" Width="125" Height="34"
                                Click="OnSelectAllClick" Background="#27AE60" Foreground="White"/>
                        <Button x:Name="ClearButton" Content="Снять все" Width="105" Height="34" Margin="8,0,0,0"
                                Click="OnClearClick" Background="#D68910" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{DynamicResource AppSecondaryTextBrush}"/>
            <Button x:Name="SaveButton" Content="Сохранить права" Width="150" Height="38" HorizontalAlignment="Right"
                    Click="OnSaveClick" Background="{DynamicResource AppAccentBrush}" Foreground="White" IsEnabled="False"/>
        </Grid>
    </Grid>
</UserControl>
