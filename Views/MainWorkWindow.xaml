<Window x:Class="BIS.ERP.MainWorkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BIS.ERP.Converters"
        Title="BIS ERP - Рабочий режим"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        AllowDrop="True">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - НАВИГАЦИЯ -->
        <Border Grid.Column="0" Background="#2C3E50">
            <DockPanel>
                <!-- Шапка -->
                <Border DockPanel.Dock="Top" Background="#1A252F" Padding="15">
                    <StackPanel>
                        <TextBlock Text="BIS ERP" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CurrentInfoBaseText" Text="Рабочий режим" 
                                   FontSize="11" Foreground="#7F8C8D" 
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Дерево навигации -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TreeView x:Name="NavigationTree" 
                              Background="#2C3E50" 
                              BorderThickness="0"
                              AllowDrop="True"
                              DragOver="NavigationTree_DragOver"
                              Drop="NavigationTree_Drop"
                              PreviewMouseMove="NavigationTree_PreviewMouseMove">
                        <TreeView.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#34495E"/>
                        </TreeView.Resources>

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="5,8"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#34495E"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#34495E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>

                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Badge}" FontSize="11" Foreground="#7F8C8D" Margin="10,0,0,0" 
                                               Visibility="{Binding HasBadge, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>

               
            </DockPanel>
        </Border>

        <!-- Правая панель - контент -->
        <Border Grid.Column="1" Background="#F5F6FA">
            <ContentControl x:Name="ContentArea" Margin="20"/>
        </Border>
    </Grid>
</Window>