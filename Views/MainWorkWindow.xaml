<Window x:Class="BIS.ERP.MainWorkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BIS.ERP.Converters"
        Title="BIS ERP - Рабочий режим"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        AllowDrop="True"
        Background="{DynamicResource AppWindowBackgroundBrush}">

    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - НАВИГАЦИЯ -->
        <Border Grid.Column="0" Background="{DynamicResource AppSidebarBackgroundBrush}">
            <DockPanel>
                <!-- Шапка -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource AppBrandHeaderBackgroundBrush}" Padding="15">
                    <StackPanel>
                        <!-- Верхняя часть с заголовком и кнопкой -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="SystemIconText" FontSize="22" Margin="0,0,8,0"
                                           Foreground="{DynamicResource AppBrandIconForegroundBrush}"/>
                                <TextBlock x:Name="SystemNameText" FontSize="22" FontWeight="Bold"
                                           Foreground="{DynamicResource AppBrandTitleForegroundBrush}"/>
                            </StackPanel>

                            <!-- Кнопка смены темы -->
                            <Button Grid.Column="1" x:Name="ThemeToggleButton" 
                                    Content="🌙" FontSize="20" 
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource AppBrandTitleForegroundBrush}" Cursor="Hand"
                                    Click="OnThemeToggleClick"
                                    ToolTip="Сменить тему"/>
                        </Grid>

                        <!-- Информация об информационной базе -->
                        <TextBlock x:Name="CurrentInfoBaseText" Text="Рабочий режим" 
                                   FontSize="11" Foreground="{DynamicResource AppBrandSubtitleForegroundBrush}" 
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Дерево навигации -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              Background="{DynamicResource AppSidebarBackgroundBrush}">
                    <TreeView x:Name="NavigationTree" 
                              Background="{DynamicResource AppSidebarBackgroundBrush}" 
                              BorderThickness="0"
                              AllowDrop="True"
                              DragOver="NavigationTree_DragOver"
                              Drop="NavigationTree_Drop"
                              PreviewMouseMove="NavigationTree_PreviewMouseMove">
                        <TreeView.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" 
                                             Color="{DynamicResource AppHighlightColor}"/>
                        </TreeView.Resources>

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="{DynamicResource AppNavigationForegroundBrush}"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="5,8"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="IsExpanded" Value="True"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AppHighlightBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AppHighlightBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>

                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Badge}" FontSize="11" 
                                               Foreground="{DynamicResource AppNavigationMutedForegroundBrush}" 
                                               Margin="10,0,0,0" 
                                               Visibility="{Binding HasBadge, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Сплиттер -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="#34495E" ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"/>

        <!-- Правая панель - контент -->
        <Border Grid.Column="2" Background="{DynamicResource AppContentBackgroundBrush}">
            <ContentControl x:Name="ContentArea" Margin="20"/>
        </Border>
    </Grid>
</Window>
