<UserControl x:Class="BIS.ERP.Views.FinanceDocumentWorkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="620" d:DesignWidth="1080">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" Foreground="#1F3448"/>
            <TextBlock x:Name="DescriptionText" FontSize="12" Foreground="#667085"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="AddButton" Content="Добавить" Width="110" Height="34" Margin="0,0,8,0"
                    Background="#27AE60" Foreground="White" Click="OnAddClick"/>
            <Button x:Name="EditButton" Content="Редактировать" Width="125" Height="34" Margin="0,0,8,0"
                    Background="#3498DB" Foreground="White" IsEnabled="False" Click="OnEditClick"/>
            <Button x:Name="DeleteButton" Content="Удалить" Width="100" Height="34" Margin="0,0,8,0"
                    Background="#E74C3C" Foreground="White" IsEnabled="False" Click="OnDeleteClick"/>
            <Button x:Name="PostButton" Content="Провести" Width="105" Height="34" Margin="0,0,8,0"
                    Background="#8E44AD" Foreground="White" IsEnabled="False" Click="OnPostClick"/>
            <Button x:Name="RefreshButton" Content="Обновить" Width="105" Height="34"
                    Background="#95A5A6" Foreground="White" Click="OnRefreshClick"/>
        </StackPanel>

        <DataGrid x:Name="DataGrid" Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionChanged="OnSelectionChanged"
                  MouseDoubleClick="OnGridDoubleClick"
                  AlternatingRowBackground="#F6F8FA"
                  BorderBrush="#D0D7DE"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер" Binding="{Binding DocumentNumber}" Width="110"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding DocumentDate, StringFormat=dd.MM.yyyy}" Width="105"/>
                <DataGridTextColumn x:Name="EmployeeColumn" Header="Сотрудник" Binding="{Binding EmployeeName}" Width="190"/>
                <DataGridTextColumn x:Name="AdvancePaymentColumn" Header="Вид расчета" Binding="{Binding AdvancePaymentName}" Width="210"/>
                <DataGridTextColumn x:Name="PeriodColumn" Header="Период" Binding="{Binding PeriodDisplay}" Width="170"/>
                <DataGridTextColumn x:Name="DebitAccountColumn" Header="Дебет" Binding="{Binding DebitAccountDisplay}" Width="160"/>
                <DataGridTextColumn x:Name="CreditAccountColumn" Header="Кредит" Binding="{Binding CreditAccountDisplay}" Width="160"/>
                <DataGridTextColumn x:Name="PaymentAccountColumn" Header="Счет выплаты" Binding="{Binding PaymentAccountDisplay}" Width="160"/>
                <DataGridTextColumn x:Name="AmountColumn" Header="Сумма" Binding="{Binding Amount}" Width="105"/>
                <DataGridTextColumn x:Name="PayableAmountColumn" Header="К выплате" Binding="{Binding PayableAmount}" Width="105"/>
                <DataGridTextColumn Header="Основание" Binding="{Binding Basis}" Width="220"/>
                <DataGridTextColumn Header="Проведен" Binding="{Binding IsPostedDisplay}" Width="90"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готово" Foreground="#667085"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>

