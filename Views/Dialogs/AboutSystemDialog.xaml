<Window x:Class="BIS.ERP.Views.Dialogs.AboutSystemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О системе" Height="520" Width="620" MinHeight="430" MinWidth="520"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppWindowBackgroundBrush}">
    <Grid Margin="26">
        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <TextBlock x:Name="IconText" FontSize="38" Margin="0,0,14,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="SystemNameText" FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource AppBodyTextBrush}"/>
                        <TextBlock Text="Корпоративная информационная система" FontSize="12"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>
                <Border Background="{DynamicResource AppSurfaceBrush}" BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1" CornerRadius="7" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <TextBlock Text="Реквизиты компании" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock x:Name="CompanyDetailsText" TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <TextBlock Text="Почта:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="EmailText" Grid.Column="1" TextWrapping="Wrap"/>
                            <TextBlock Text="Телефон:" FontWeight="SemiBold" Margin="0,28,0,0"/>
                            <TextBlock x:Name="PhoneText" Grid.Column="1" Margin="0,28,0,0" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <TextBlock Text="Версия 1.0" Foreground="{DynamicResource AppSecondaryTextBrush}"
                           HorizontalAlignment="Right" Margin="0,10,0,0"/>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="1" Content="Закрыть" Width="110" Height="38" HorizontalAlignment="Right"
                Margin="0,18,0,0" IsCancel="True" Background="{DynamicResource AppAccentBrush}" Foreground="White"/>
    </Grid>
</Window>
