<Window x:Class="BIS.ERP.Views.PostingDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали проводки" Height="520" Width="580"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" FontSize="18" Foreground="#2C3E50"/>
        </Border>

        <!-- Детали проводки -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0"
                          Foreground="#333333">
                <StackPanel x:Name="DetailsPanel" Margin="10,5"/>
            </ScrollViewer>
        </Border>

        <!-- Кнопка закрытия -->
        <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="15" Margin="0,15,0,0">
            <Button Content="Закрыть" Width="120" Height="36"
                    HorizontalAlignment="Right"
                    Click="OnCloseClick"
                    Background="#3498DB" Foreground="White"
                    FontSize="13"
                    Cursor="Hand"/>
        </Border>
    </Grid>
</Window>
