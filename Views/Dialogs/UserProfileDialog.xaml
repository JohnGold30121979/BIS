<Window x:Class="BIS.ERP.Views.Dialogs.UserProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профиль пользователя"
        Width="480"
        Height="520"
        MinWidth="440"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Background="#F4F7FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="18" BorderBrush="#D9E2EC" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Профиль пользователя" FontSize="22" FontWeight="Bold" Foreground="#102A43"/>
                <TextBlock x:Name="InfoBaseText" Margin="0,5,0,0" Foreground="#52606D" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel Margin="18">
                <Border Background="White" BorderBrush="#D9E2EC" BorderThickness="1" CornerRadius="8" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Пользователь:" Foreground="#52606D" Margin="0,0,8,8"/>
                        <TextBlock x:Name="FullNameText" Grid.Row="0" Grid.Column="1" FontWeight="SemiBold" Foreground="#102A43" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Логин:" Foreground="#52606D" Margin="0,0,8,8"/>
                        <TextBlock x:Name="LoginText" Grid.Row="1" Grid.Column="1" Foreground="#102A43" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Email:" Foreground="#52606D" Margin="0,0,8,8"/>
                        <TextBlock x:Name="EmailText" Grid.Row="2" Grid.Column="1" Foreground="#102A43" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Роль:" Foreground="#52606D" Margin="0,0,8,0"/>
                        <TextBlock x:Name="RoleText" Grid.Row="3" Grid.Column="1" Foreground="#102A43"/>
                    </Grid>
                </Border>

                <Border Background="#EAF6FF" BorderBrush="#B6E0FE" BorderThickness="1" CornerRadius="8"
                        Padding="12" Margin="0,14,0,14">
                    <TextBlock Foreground="#0B5CAD" TextWrapping="Wrap">
                        Пароль меняется для пользователя в текущей информационной базе. В других инфобазах у этого логина может быть свой отдельный пароль.
                    </TextBlock>
                </Border>

                <TextBlock Text="Смена пароля" FontSize="16" FontWeight="SemiBold" Foreground="#102A43" Margin="0,0,0,10"/>

                <TextBlock Text="Текущий пароль" Foreground="#243B53" Margin="0,0,0,5"/>
                <PasswordBox x:Name="CurrentPasswordBox" Height="36" Padding="9" Margin="0,0,0,12"/>

                <TextBlock Text="Новый пароль" Foreground="#243B53" Margin="0,0,0,5"/>
                <PasswordBox x:Name="NewPasswordBox" Height="36" Padding="9" Margin="0,0,0,12"/>

                <TextBlock Text="Подтверждение нового пароля" Foreground="#243B53" Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Height="36" Padding="9" Margin="0,0,0,8"/>

                <TextBlock x:Name="ErrorText" Foreground="#C0392B" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="16" BorderBrush="#D9E2EC" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сменить пароль" Width="145" Height="36" Background="#27AE60" Foreground="White"
                        Click="OnChangePasswordClick"/>
                <Button Content="Закрыть" Width="110" Height="36" Margin="8,0,0,0" Background="#95A5A6" Foreground="White"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
