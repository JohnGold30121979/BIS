<Window x:Class="BIS.ERP.Views.ReferenceSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор записи" Height="450" Width="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="SearchBox" Grid.Row="0" Height="30" Margin="0,0,0,10" 
                 TextChanged="SearchBox_TextChanged" ToolTip="Введите текст для поиска"/>

        <DataGrid x:Name="ItemsGrid" Grid.Row="1" AutoGenerateColumns="True"
                  IsReadOnly="True" SelectionMode="Single" 
                  SelectionChanged="ItemsGrid_SelectionChanged"
                  MouseDoubleClick="ItemsGrid_MouseDoubleClick"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SelectButton" Content="Выбрать" Width="100" Height="30" Margin="0,0,10,0" 
                    Click="OnSelectClick" IsDefault="True" IsEnabled="False"/>
            <Button Content="Отмена" Width="100" Height="30" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
