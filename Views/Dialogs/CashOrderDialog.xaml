<Window x:Class="BIS.ERP.Views.CashOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кассовый ордер" Height="550" Width="450"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Name="DialogTitle" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Номер:" VerticalAlignment="Center"/>
        <TextBox x:Name="NumberBox" Grid.Row="1" Grid.Column="1" Height="30" IsReadOnly="True" Background="LightGray"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата:" VerticalAlignment="Center"/>
        <DatePicker x:Name="DatePicker" Grid.Row="2" Grid.Column="1" Height="30"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Касса:" VerticalAlignment="Center"/>
        <ComboBox x:Name="CashDeskCombo" Grid.Row="3" Grid.Column="1" Height="30"
                  DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Организация:" VerticalAlignment="Center"/>
        <ComboBox x:Name="OrganizationCombo" Grid.Row="4" Grid.Column="1" Height="30"
                  DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Контрагент:" VerticalAlignment="Center"/>
        <ComboBox x:Name="ContractorCombo" Grid.Row="5" Grid.Column="1" Height="30"
                  DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Сумма:" VerticalAlignment="Center"/>
        <TextBox x:Name="AmountBox" Grid.Row="6" Grid.Column="1" Height="30"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Основание:" VerticalAlignment="Center"/>
        <TextBox x:Name="BasisBox" Grid.Row="7" Grid.Column="1" Height="30"/>

        <TextBlock Grid.Row="8" Grid.Column="0" Text="Корр. счет:" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
            <TextBox x:Name="CorrAccountBox" Width="250" Height="30" IsReadOnly="True" Background="LightGray"/>
            <Button Content="?" Width="30" Height="30" Margin="5,0,0,0" Click="SelectAccount_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Примечание:" VerticalAlignment="Top"/>
        <TextBox x:Name="DescriptionBox" Grid.Row="9" Grid.Column="1" Height="60" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0" Click="OnSaveClick"
                    Background="#27AE60" Foreground="White"/>
            <Button Content="Отмена" Width="100" Height="35" Click="OnCancelClick"
                    Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>