<Window x:Class="BIS.ERP.Views.PaymentOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Платежное поручение" Height="650" Width="550"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Name="DialogTitle" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Номер:" VerticalAlignment="Center"/>
        <TextBox x:Name="NumberBox" Grid.Row="1" Grid.Column="1" Height="30" IsReadOnly="True" Background="LightGray"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Дата:" VerticalAlignment="Center"/>
        <DatePicker x:Name="DatePicker" Grid.Row="2" Grid.Column="1" Height="30"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Тип:" VerticalAlignment="Center"/>
        <ComboBox x:Name="TypeCombo" Grid.Row="3" Grid.Column="1" Height="30">
            <ComboBoxItem Content="Исходящее (оплата)" Tag="Outgoing"/>
            <ComboBoxItem Content="Входящее (поступление)" Tag="Incoming"/>
        </ComboBox>

        <TextBlock x:Name="OrganizationLabel" Grid.Row="4" Grid.Column="0" Text="Организация:" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
        <ComboBox x:Name="OrganizationCombo" Grid.Row="4" Grid.Column="1" Height="30"
                  DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                  Visibility="Collapsed"/>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2">
            <Grid x:Name="EmployeePanel" Visibility="Collapsed" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Сотрудник:" VerticalAlignment="Center"/>
                <ComboBox x:Name="EmployeeCombo" Grid.Column="1" Height="30"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>
            </Grid>

            <Grid x:Name="MaterialPanel" Visibility="Collapsed" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Материал:" VerticalAlignment="Center"/>
                <ComboBox x:Name="MaterialCombo" Grid.Column="1" Height="30"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>
            </Grid>
        </StackPanel>

        <TextBlock x:Name="BankLabel" Grid.Row="6" Grid.Column="0" Text="Банк:" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
        <ComboBox x:Name="BankCombo" Grid.Row="6" Grid.Column="1" Height="30"
                  DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                  Visibility="Collapsed"/>

        <TextBlock x:Name="OurAccountLabel" Grid.Row="8" Grid.Column="0" Text="Наш счет:" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
        <ComboBox x:Name="OurAccountCombo" Grid.Row="8" Grid.Column="1" Height="30"
                  DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                  Visibility="Collapsed"/>

        <TextBlock Grid.Row="9" Grid.Column="0" Text="Сумма:" VerticalAlignment="Center"/>
        <TextBox x:Name="AmountBox" Grid.Row="9" Grid.Column="1" Height="30" Text="0"/>

        <TextBlock x:Name="CurrencyLabel" Grid.Row="10" Grid.Column="0" Text="Валюта:" VerticalAlignment="Center"
                   Visibility="Collapsed"/>
        <ComboBox x:Name="CurrencyCombo" Grid.Row="10" Grid.Column="1" Height="30"
                  DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                  Visibility="Collapsed"/>

        <TextBlock Grid.Row="11" Grid.Column="0" Text="Корр. счет:" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="11" Grid.Column="1" Orientation="Horizontal">
            <TextBox x:Name="CorrAccountBox" Width="250" Height="30" IsReadOnly="True" Background="LightGray"/>
            <Button Content="?" Width="30" Height="30" Margin="5,0,0,0" Click="SelectAccount_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="12" Grid.Column="0" Text="Назначение:" VerticalAlignment="Top"/>
        <TextBox x:Name="PurposeBox" Grid.Row="12" Grid.Column="1" Height="60" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="13" Grid.Column="0" Text="Примечание:" VerticalAlignment="Top"/>
        <TextBox x:Name="DescriptionBox" Grid.Row="13" Grid.Column="1" Height="60" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="14" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="120" Height="35" Margin="0,0,10,0" Click="OnSaveClick"
                    Background="#27AE60" Foreground="White"/>
            <Button Content="Отмена" Width="120" Height="35" Click="OnCancelClick"
                    Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
