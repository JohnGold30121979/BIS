<Window x:Class="BIS.ERP.Views.Dialogs.AppUpdateBuildSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Параметры обновления программы"
        Height="560" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Параметры сборки обновления программы" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Проверьте версию и описание перед созданием зашифрованного .bisapp."
                       Foreground="#6C7A89" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="UpdateId:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,8"/>
            <TextBox x:Name="UpdateIdBox" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Версия программы:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,8"/>
            <TextBox x:Name="VersionBox" Grid.Row="1" Grid.Column="1" Height="30" Margin="0,0,0,8"
                     ToolTip="Например: 2.0.0"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Наименование:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,8"/>
            <TextBox x:Name="NameBox" Grid.Row="2" Grid.Column="1" Height="30" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Автор:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,8"/>
            <TextBox x:Name="AuthorBox" Grid.Row="3" Grid.Column="1" Height="30" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Мин. версия:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,8"/>
            <TextBox x:Name="MinAppVersionBox" Grid.Row="4" Grid.Column="1" Height="30" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Запускать:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,8"/>
            <TextBox x:Name="RestartExecutableBox" Grid.Row="5" Grid.Column="1" Height="30" Margin="0,0,0,8"
                     ToolTip="Обычно BIS.ERP.exe"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Описание:" VerticalAlignment="Top" FontWeight="SemiBold" Margin="0,4,8,0"/>
            <TextBox x:Name="DescriptionBox" Grid.Row="6" Grid.Column="1"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock x:Name="HintText" DockPanel.Dock="Left" Foreground="#7F8C8D" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Продолжить" Width="120" Height="34" Margin="0,0,8,0"
                        Background="#27AE60" Foreground="White" Click="OnSaveClick"/>
                <Button Content="Отмена" Width="100" Height="34"
                        Background="#95A5A6" Foreground="White" Click="OnCancelClick"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
