<Window x:Class="BIS.ERP.Views.Dialogs.TerminationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Увольнение сотрудника"
        Height="250" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Сотрудник:" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBlock x:Name="txtEmployeeName" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата увольнения:" VerticalAlignment="Center" FontWeight="Bold"/>
        <DatePicker x:Name="dpTerminationDate" Grid.Row="1" Grid.Column="1" Height="30" Margin="0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Причина:" VerticalAlignment="Center" FontWeight="Bold"/>
        <ComboBox x:Name="cmbReason" Grid.Row="2" Grid.Column="1" Height="30" Margin="0,5" SelectedIndex="0">
            <ComboBoxItem Content="Уволен"/>
            <ComboBoxItem Content="По собственному желанию"/>
            <ComboBoxItem Content="Сокращение"/>
            <ComboBoxItem Content="Окончание договора"/>
        </ComboBox>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="✅ Уволить" Click="OnTerminateClick" Width="100" Height="35" Margin="5"
                    Background="#FF9800" Foreground="White"/>
            <Button Content="❌ Отмена" Click="OnCancelClick" Width="100" Height="35" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>