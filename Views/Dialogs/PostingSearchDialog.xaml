<Window x:Class="BIS.ERP.Views.PostingSearchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поиск проводок" Height="450" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="SearchBox" Width="300" Height="30" Margin="0,0,10,0" 
                     TextChanged="OnSearchClick"/>
            <Button Content="🔍 Поиск" Width="80" Height="30" Click="OnSearchClick"
                    Background="#F39C12" Foreground="White"/>
        </StackPanel>

        <DataGrid x:Name="SearchResultsGrid" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" MouseDoubleClick="SearchResultsGrid_MouseDoubleClick"
                  AlternatingRowBackground="#F5F5F5"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" Text="Готово" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <Button Content="Выбрать" Width="80" Height="30" Margin="0,0,10,0" 
                    Click="OnSelectClick" Background="#27AE60" Foreground="White"/>
            <Button Content="Отмена" Width="80" Height="30" Click="OnCancelClick" 
                    Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>