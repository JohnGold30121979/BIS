<Window x:Class="BIS.ERP.Views.Dialogs.EditInfoBaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение информационной базы" Height="240" Width="480"
        MinWidth="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Изменение информационной базы" FontSize="18" FontWeight="Bold" Margin="0,0,0,18"/>
        <TextBlock Grid.Row="1" Text="Наименование" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox" Grid.Row="2" Height="36" Padding="8,5"/>
        <TextBlock x:Name="ErrorText" Grid.Row="3" Foreground="#C0392B" Margin="0,8,0,0"
                   Visibility="Collapsed"/>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Сохранить" Width="110" Height="36" Margin="0,0,10,0"
                    Background="#27AE60" Foreground="White" Click="OnSaveClick"/>
            <Button Content="Отмена" Width="110" Height="36"
                    Background="#95A5A6" Foreground="White" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
