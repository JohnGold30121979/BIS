<Window x:Class="BIS.ERP.Views.Dialogs.EditInfoBaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение информационной базы" Height="440" Width="520"
        MinWidth="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Изменение информационной базы" FontSize="18" FontWeight="Bold" Margin="0,0,0,18"/>
        <TextBlock Grid.Row="1" Text="Наименование" Margin="0,0,0,6"/>
        <TextBox x:Name="NameBox" Grid.Row="2" Height="36" Padding="8,5"/>
        <TextBlock Grid.Row="3" Text="Иконка" Margin="0,14,0,6"/>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="IconCombo" Height="36" SelectionChanged="OnIconSelected">
                <ComboBoxItem Content="🏢 Системная" Tag="🏢"/>
                <ComboBoxItem Content="📊 Финансы" Tag="📊"/>
                <ComboBoxItem Content="🏭 Организация" Tag="🏭"/>
                <ComboBoxItem Content="🏦 Банк" Tag="🏦"/>
                <ComboBoxItem Content="📦 Склад" Tag="📦"/>
                <ComboBoxItem Content="🏗 Основные средства" Tag="🏗"/>
                <ComboBoxItem Content="👥 Персонал" Tag="👥"/>
            </ComboBox>
            <TextBox x:Name="IconBox" Grid.Column="2" Height="36" Padding="8,5"
                     FontSize="16" TextAlignment="Center"
                     ToolTip="Можно ввести любую emoji-иконку вручную"/>
        </Grid>

        <TextBlock Grid.Row="5" Text="Логотип организации" Margin="0,14,0,6"/>
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Width="56" Height="56" CornerRadius="8"
                    Background="{DynamicResource AppReadOnlyBackgroundBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                <Grid>
                    <Image x:Name="LogoPreviewImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                    <TextBlock x:Name="LogoPlaceholderText" Text="🏢" FontSize="24"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock x:Name="LogoNameText" Text="Логотип не загружен"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Загрузить PNG/ICO" Width="145" Height="32"
                            Background="#3498DB" Foreground="White"
                            Click="OnLoadLogoClick"/>
                    <Button Content="Убрать" Width="80" Height="32" Margin="8,0,0,0"
                            Background="#95A5A6" Foreground="White"
                            Click="OnClearLogoClick"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="ErrorText" Grid.Row="7" Foreground="#C0392B" Margin="0,8,0,0"
                   Visibility="Collapsed"/>
        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Сохранить" Width="110" Height="36" Margin="0,0,10,0"
                    Background="#27AE60" Foreground="White" Click="OnSaveClick"/>
            <Button Content="Отмена" Width="110" Height="36"
                    Background="#95A5A6" Foreground="White" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
