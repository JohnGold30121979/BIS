<Window x:Class="BIS.ERP.Views.Dialogs.InvoiceEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Счет-фактура" Height="720" Width="1050"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="DialogTitle" Grid.Row="0" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,8">
                <TextBlock Text="Номер"/>
                <TextBox x:Name="NumberBox" Height="28"/>
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,8">
                <TextBlock Text="Дата"/>
                <DatePicker x:Name="DatePicker" Height="28"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,8">
                <TextBlock Text="Кому"/>
                <ComboBox x:Name="OrganizationCombo" Height="28" DisplayMemberPath="DisplayName"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,8">
                <TextBlock Text="Номер ЭСФ"/>
                <TextBox x:Name="EsfNumberBox" Height="28"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,8">
                <TextBlock Text="Счет стороны Б"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="AccountBox" Height="28" IsReadOnly="True"/>
                    <Button x:Name="HeaderAccountButton" Grid.Column="1" Content="..." Width="32" Height="28" Margin="4,0,0,0" Click="OnSelectAccountClick"/>
                </Grid>
            </StackPanel>
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,8">
                <TextBlock Text="Основание"/>
                <TextBox x:Name="BasisBox" Height="28"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,8">
                <TextBlock Text="Вид оплаты"/>
                <ComboBox x:Name="PaymentKindCombo" Height="28" DisplayMemberPath="DisplayName" SelectedValuePath="Value"/>
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,8">
                <TextBlock Text="Вид поставки"/>
                <ComboBox x:Name="DeliveryKindCombo" Height="28" DisplayMemberPath="DisplayName" SelectedValuePath="Value"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="Тип поставки"/>
                <ComboBox x:Name="SupplyKindCombo" Height="28" DisplayMemberPath="DisplayName" SelectedValuePath="Value"/>
            </StackPanel>
        </Grid>

        <DataGrid x:Name="LinesGrid" Grid.Row="2" AutoGenerateColumns="False"
                  CanUserAddRows="False" SelectionChanged="OnLineSelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2.4*"/>
                <DataGridTemplateColumn Header="Счет стороны А" Width="190">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding AccountDisplayName}" IsReadOnly="True" Height="24"/>
                                <Button Grid.Column="1" Content="..." Width="28" Height="24" Margin="4,0,0,0"
                                        Tag="{Binding}" Click="OnSelectLineAccountClick"
                                        IsEnabled="{Binding DataContext.IsInvoiceEditingEnabled, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Без налогов" Binding="{Binding AmountWithoutTax, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"/>
                <DataGridTemplateColumn Header="НДС" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.VatTaxItems, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="DisplayName" SelectedValuePath="Value"
                                      SelectedValue="{Binding VatTaxCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextSearchEnabled="True"
                                      IsEnabled="{Binding DataContext.IsInvoiceEditingEnabled, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="% НДС" Binding="{Binding VatRate, StringFormat=N2}" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Header="Сумма НДС" Binding="{Binding VatAmount, StringFormat=N2}" Width="90" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Налог с прод." Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.SalesTaxItems, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="DisplayName" SelectedValuePath="Value"
                                      SelectedValue="{Binding SalesTaxCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsTextSearchEnabled="True"
                                      IsEnabled="{Binding DataContext.IsInvoiceEditingEnabled, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="% НП" Binding="{Binding SalesTaxRate, StringFormat=N2}" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Header="Сумма НП" Binding="{Binding SalesTaxAmount, StringFormat=N2}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Итого" Binding="{Binding LineTotal, StringFormat=N2}" Width="100" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <WrapPanel Grid.Row="3" Margin="0,8,0,8">
            <Button x:Name="AddLineButton" Content="Добавить строку" Width="120" Height="32" Margin="0,0,8,0" Click="OnAddLineClick"/>
            <Button x:Name="DeleteLineButton" Content="Удалить строку" Width="120" Height="32" Margin="0,0,8,0"
                    IsEnabled="False" Click="OnDeleteLineClick"/>
            <Button x:Name="LinePostingsButton" Content="Проводки по строке" Width="140" Height="32" Margin="0,0,8,0"
                    IsEnabled="False" Click="OnLinePostingsClick"/>
            <Button x:Name="AllPostingsButton" Content="Все проводки" Width="120" Height="32" Margin="0,0,8,0"
                    IsEnabled="False" Click="OnAllPostingsClick"/>
            <Button x:Name="RecalculateButton" Content="Пересчет" Width="100" Height="32" Click="OnRecalculateClick"/>
        </WrapPanel>

        <Grid Grid.Row="4" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Без налогов"/>
                <TextBlock x:Name="TotalWithoutTaxText" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="НДС"/>
                <TextBlock x:Name="TotalVatText" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Налог с продаж"/>
                <TextBlock x:Name="TotalSalesTaxText" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Grid.Column="3">
                <TextBlock Text="Итого в нац.вал."/>
                <TextBlock x:Name="TotalAmountText" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="ModeHintText" Grid.Row="5"
                   Text="Режим просмотра: изменения недоступны. Для изменения используйте кнопку «Редактировать» или «Корректировка»."
                   Foreground="#7F8C8D" FontStyle="Italic" Visibility="Collapsed" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Запись" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#27AE60" Foreground="White" Click="OnSaveClick"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="35"
                    Background="#95A5A6" Foreground="White" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
