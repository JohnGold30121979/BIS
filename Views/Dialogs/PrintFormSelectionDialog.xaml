<Window x:Class="BIS.ERP.Views.Dialogs.PrintFormSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор печатной формы" Height="480" Width="760"
        MinHeight="380" MinWidth="620" WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Margin="0,0,0,10">
            <TextBlock Text="Печатные формы документа" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Отключенные формы видны для контроля, но недоступны для печати."
                       Foreground="{DynamicResource AppSecondaryTextBrush}"/>
        </StackPanel>
        <DataGrid x:Name="FormsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single" MouseDoubleClick="OnGridDoubleClick"
                  SelectionChanged="OnSelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*" MinWidth="260"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding AvailabilityDisplay}" Width="100"/>
                <DataGridTextColumn Header="Формат" Binding="{Binding SourceFormat}" Width="110"/>
                <DataGridCheckBoxColumn Header="Основная" Binding="{Binding IsDefault}" Width="80"/>
                <DataGridTextColumn Header="Версия" Binding="{Binding TemplateVersion}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SelectButton" Content="Сформировать PDF" Width="150" Height="36"
                    Margin="0,0,10,0" Background="#27AE60" Foreground="White"
                    IsEnabled="False" Click="OnSelectClick"/>
            <Button Content="Отмена" Width="110" Height="36" Background="#95A5A6" Foreground="White"
                    Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
