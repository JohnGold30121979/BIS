<Window x:Class="BIS.ERP.Views.Dialogs.RegulatedTemplateUploadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Загрузка шаблона"
        Height="410" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center"
                   Text="Файл шаблона:" FontWeight="SemiBold"/>
        <TextBox x:Name="FilePathTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"
                 IsReadOnly="True" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center"
                   Text="Код формы:" FontWeight="SemiBold"/>
        <TextBox x:Name="CodeTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center"
                   Text="Название:" FontWeight="SemiBold"/>
        <TextBox x:Name="NameTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center"
                   Text="Версия:" FontWeight="SemiBold"/>
        <TextBox x:Name="VersionTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Top"
                   Text="Описание:" FontWeight="SemiBold"/>
        <StackPanel Grid.Row="4" Grid.Column="1">
            <TextBox x:Name="DescriptionTextBox" Height="120" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
            <CheckBox x:Name="IsActiveCheckBox" Margin="0,10,0,0" IsChecked="True"
                      Content="Сделать этот шаблон активным для выбранного кода"/>
            <TextBlock Margin="0,8,0,0" Foreground="Gray" TextWrapping="Wrap"
                       Text="Для экспорта НДС система автоматически ищет активный шаблон с кодом STI-062_7."/>
        </StackPanel>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Сохранить" Width="110" Height="34" Margin="0,0,8,0"
                    Background="#27AE60" Foreground="White" Click="OnSaveClick"/>
            <Button Content="Отмена" Width="110" Height="34" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
