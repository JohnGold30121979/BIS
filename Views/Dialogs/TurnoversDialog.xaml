<Window x:Class="BIS.ERP.Views.Dialogs.TurnoversDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обороты по счету"
        Height="500" Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="TurnoversGrid" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" AlternatingRowBackground="#F8F9FA"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Печать" Click="OnPrintClick" Width="100" Height="35" Margin="5"
                    Background="#3498DB" Foreground="White"/>
            <Button Content="Закрыть" Click="OnCloseClick" Width="100" Height="35" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>