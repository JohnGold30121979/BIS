<Window x:Class="BIS.ERP.Views.Dialogs.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить пользователя"
        Width="480"
        Height="560"
        MinWidth="440"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Background="#F4F7FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="18" BorderBrush="#D9E2EC" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Добавить пользователя" FontSize="22" FontWeight="Bold" Foreground="#102A43"/>
                <TextBlock Text="Пользователь будет создан в текущей информационной базе."
                           Margin="0,4,0,0" Foreground="#52606D" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="18">
                <TextBlock Text="Логин" Foreground="#243B53" Margin="0,0,0,5"/>
                <TextBox x:Name="LoginBox" Height="34" Padding="9" Margin="0,0,0,10"/>

                <TextBlock Text="Полное имя" Foreground="#243B53" Margin="0,0,0,5"/>
                <TextBox x:Name="FullNameBox" Height="34" Padding="9" Margin="0,0,0,10"/>

                <TextBlock Text="Email" Foreground="#243B53" Margin="0,0,0,5"/>
                <TextBox x:Name="EmailBox" Height="34" Padding="9" Margin="0,0,0,10"/>

                <TextBlock Text="Роль" Foreground="#243B53" Margin="0,0,0,5"/>
                <ComboBox x:Name="RoleBox" Height="34" Padding="7,4" Margin="0,0,0,10"
                          DisplayMemberPath="Name"
                          SelectionChanged="OnRoleSelectionChanged"/>

                <CheckBox x:Name="ActiveCheckBox" Content="Активен" IsChecked="True" Margin="0,0,0,14"/>

                <TextBlock Text="Пароль" Foreground="#243B53" Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox" Height="34" Padding="9" Margin="0,0,0,10"/>

                <TextBlock Text="Подтверждение пароля" Foreground="#243B53" Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Height="34" Padding="9" Margin="0,0,0,8"/>

                <TextBlock x:Name="ErrorText" Foreground="#C0392B" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="16" BorderBrush="#D9E2EC" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Добавить" Width="120" Height="36" Background="#27AE60" Foreground="White"
                        Click="OnSaveClick"/>
                <Button Content="Отмена" Width="105" Height="36" Margin="8,0,0,0" Background="#95A5A6" Foreground="White"
                        Click="OnCancelClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
