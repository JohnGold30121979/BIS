<Window x:Class="BIS.ERP.Views.Dialogs.FoxProAnalysisDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализ FoxPro-проекта" Height="720" Width="1180"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Анализ FoxPro-проекта" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Чтение исходников Visual FoxPro: PRG, SCX, FRX, DBF, PJX. Анализатор ничего не меняет в инфобазе."
                       Foreground="#6C7A89" TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Папка:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="ProjectPathBox" Grid.Column="1" Height="32" VerticalContentAlignment="Center"/>
            <Button Grid.Column="2" Content="Выбрать..." Width="100" Height="32" Margin="8,0,0,0"
                    Click="OnBrowseClick"/>
            <Button Grid.Column="3" Content="Анализировать" Width="120" Height="32" Margin="8,0,0,0"
                    Background="#27AE60" Foreground="White" Click="OnAnalyzeClick"/>
            <Button x:Name="SaveJsonButton" Grid.Column="4" Content="Сохранить JSON" Width="125" Height="32"
                    Margin="8,0,0,0" Background="#2980B9" Foreground="White"
                    IsEnabled="False" Click="OnSaveJsonClick"/>
            <Button x:Name="OpenCodeButton" Grid.Column="5" Content="VS Code" Width="85" Height="32"
                    Margin="8,0,0,0" Background="#34495E" Foreground="White"
                    IsEnabled="False" Click="OnOpenInVsCodeClick"/>
            <Button x:Name="OpenTextButton" Grid.Column="6" Content="TXT" Width="65" Height="32"
                    Margin="8,0,0,0" Background="#7F8C8D" Foreground="White"
                    IsEnabled="False" Click="OnOpenAsTextClick"/>
        </Grid>

        <TabControl x:Name="AnalysisTabs" Grid.Row="2">
            <TabItem Header="Итог">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#F4F6F9" BorderBrush="#D5DCE5"
                            BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                        <TextBlock x:Name="SummaryText" Text="Выберите папку и запустите анализ."
                                   TextWrapping="Wrap" LineHeight="20"/>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid x:Name="ExtensionGrid" Grid.Column="0" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserAddRows="False" AlternatingRowBackground="#F8F9FA">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Расширение" Binding="{Binding Extension}" Width="120"/>
                                <DataGridTextColumn Header="Количество" Binding="{Binding Count}" Width="120"/>
                                <DataGridTextColumn Header="Размер, байт" Binding="{Binding TotalBytes}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <ListBox x:Name="WarningsList" Grid.Column="1" Margin="10,0,0,0"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Файлы">
                <DataGrid x:Name="FilesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" AlternatingRowBackground="#F8F9FA"
                          MouseDoubleClick="OnOpenSelectedInVsCodeClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Файл" Binding="{Binding Name}" Width="220"/>
                        <DataGridTextColumn Header="Путь" Binding="{Binding RelativePath}" Width="*"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding Category}" Width="150"/>
                        <DataGridTextColumn Header="Размер" Binding="{Binding SizeBytes}" Width="100"/>
                        <DataGridTextColumn Header="Изменен" Binding="{Binding LastWriteTime, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Вызовы">
                <DataGrid x:Name="ReferencesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" AlternatingRowBackground="#F8F9FA"
                          MouseDoubleClick="OnOpenSelectedInVsCodeClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Тип" Binding="{Binding ReferenceType}" Width="130"/>
                        <DataGridTextColumn Header="Цель" Binding="{Binding Target}" Width="220"/>
                        <DataGridTextColumn Header="Файл" Binding="{Binding SourceFile}" Width="220"/>
                        <DataGridTextColumn Header="Строка" Binding="{Binding LineNumber}" Width="70"/>
                        <DataGridTextColumn Header="Код" Binding="{Binding RawText}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Определения">
                <DataGrid x:Name="DefinitionsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" AlternatingRowBackground="#F8F9FA"
                          MouseDoubleClick="OnOpenSelectedInVsCodeClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Тип" Binding="{Binding Kind}" Width="120"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="220"/>
                        <DataGridTextColumn Header="Файл" Binding="{Binding SourceFile}" Width="240"/>
                        <DataGridTextColumn Header="Строка" Binding="{Binding LineNumber}" Width="70"/>
                        <DataGridTextColumn Header="Код" Binding="{Binding RawText}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="DBF/SCX/FRX">
                <DataGrid x:Name="DbfGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" AlternatingRowBackground="#F8F9FA"
                          MouseDoubleClick="OnOpenSelectedInVsCodeClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Файл" Binding="{Binding FileName}" Width="220"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding Extension}" Width="80"/>
                        <DataGridTextColumn Header="Записей" Binding="{Binding RecordCount}" Width="90"/>
                        <DataGridTextColumn Header="Полей" Binding="{Binding Fields.Count}" Width="70"/>
                        <DataGridTextColumn Header="Длина записи" Binding="{Binding RecordLength}" Width="100"/>
                        <DataGridTextColumn Header="Путь" Binding="{Binding RelativePath}" Width="*"/>
                        <DataGridTextColumn Header="Ошибка" Binding="{Binding Error}" Width="220"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Таблицы в коде">
                <DataGrid x:Name="TableUsagesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" AlternatingRowBackground="#F8F9FA"
                          MouseDoubleClick="OnOpenSelectedInVsCodeClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Операция" Binding="{Binding Operation}" Width="120"/>
                        <DataGridTextColumn Header="Таблица/выражение" Binding="{Binding TableName}" Width="220"/>
                        <DataGridTextColumn Header="Файл" Binding="{Binding SourceFile}" Width="220"/>
                        <DataGridTextColumn Header="Строка" Binding="{Binding LineNumber}" Width="70"/>
                        <DataGridTextColumn Header="Код" Binding="{Binding RawText}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" DockPanel.Dock="Left" Foreground="#6C7A89"
                       VerticalAlignment="Center" Text="Готово"/>
            <Button DockPanel.Dock="Right" Content="Закрыть" Width="100" Height="34"
                    Background="#95A5A6" Foreground="White" Click="OnCloseClick"/>
        </DockPanel>
    </Grid>
</Window>
