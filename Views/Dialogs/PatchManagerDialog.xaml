<Window x:Class="BIS.ERP.Views.Dialogs.PatchManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Патчи инфобазы" Height="560" Width="920"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Патчи инфобазы" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="История обновлений структуры, метаданных, отчетов и настроек текущей инфобазы."
                       Foreground="#6C7A89" TextWrapping="Wrap"/>
        </StackPanel>

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <Button Content="Собрать патч..." Width="130" Height="34" Margin="0,0,8,0"
                    Background="#8E44AD" Foreground="White" Click="OnBuildPatchClick"/>
            <Button Content="Загрузить патч..." Width="140" Height="34" Margin="0,0,8,0"
                    Background="#27AE60" Foreground="White" Click="OnApplyPatchClick"/>
            <Button Content="Обновить" Width="100" Height="34" Margin="0,0,8,0"
                    Background="#3498DB" Foreground="White" Click="OnRefreshClick"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#7F8C8D"/>
        </WrapPanel>

        <DataGrid x:Name="PatchesGrid" Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  AlternatingRowBackground="#F8F9FA">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Патч" Binding="{Binding PatchId}" Width="150"/>
                <DataGridTextColumn Header="Версия" Binding="{Binding Version}" Width="80"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="Применен" Binding="{Binding AppliedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="135"/>
                <DataGridTextColumn Header="Пользователь" Binding="{Binding AppliedBy}" Width="120"/>
                <DataGridTextColumn Header="Ошибка" Binding="{Binding Error}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock DockPanel.Dock="Left"
                       Text="Формат: зашифрованный .bispatch. Повторно применить уже установленный патч нельзя."
                       Foreground="#7F8C8D" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Content="Закрыть" Width="100" Height="34"
                    Background="#95A5A6" Foreground="White" Click="OnCloseClick"/>
        </DockPanel>
    </Grid>
</Window>
