<Window x:Class="BIS.ERP.Views.AccountSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="План счетов - выберите счет" Height="500" Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="AccountsGrid" Grid.Row="0" AutoGenerateColumns="True" 
                  IsReadOnly="True" MouseDoubleClick="AccountsGrid_MouseDoubleClick"
                  AlternatingRowBackground="#F5F5F5"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Выбрать" Width="80" Height="30" Margin="0,0,10,0" 
                    Click="OnOkClick" Background="#27AE60" Foreground="White"/>
            <Button Content="Отмена" Width="80" Height="30" Click="OnCancelClick" 
                    Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>