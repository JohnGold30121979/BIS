<Window x:Class="BIS.ERP.Views.AccountSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="План счетов - выберите счет" Height="500" Width="650"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ручное определение колонок для понятного отображения -->
        <DataGrid x:Name="AccountsGrid" Grid.Row="0" AutoGenerateColumns="False" 
                  IsReadOnly="True" MouseDoubleClick="AccountsGrid_MouseDoubleClick"
                  AlternatingRowBackground="#F5F5F5" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding [Код]}" Width="100"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding [Наименование]}" Width="300"/>
                <DataGridTextColumn Header="Тип счета" Binding="{Binding [Тип счета]}" Width="120"/>
                <DataGridTextColumn Header="Активен" Binding="{Binding [Активен]}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Выбрать" Width="100" Height="35" Margin="0,0,10,0" 
                    Click="OkButton_Click" Background="#27AE60" Foreground="White"/>
            <Button Content="Отмена" Width="100" Height="35" Click="CancelButton_Click" 
                    Background="#E74C3C" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>