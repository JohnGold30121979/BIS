<Window x:Class="BIS.ERP.Views.Dialogs.InvoiceEsfExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выгрузка ЭСФ"
        Width="500"
        Height="330"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Выберите режим выгрузки электронных счет-фактур"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1" Padding="12" BorderBrush="#D5DBDB" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
            <StackPanel>
                <RadioButton x:Name="SelectedInvoiceRadio"
                             Content="Одна выбранная счет-фактура"
                             FontWeight="SemiBold"
                             Checked="OnModeChanged"/>
                <TextBlock x:Name="SelectedInvoiceText"
                           Margin="22,6,0,0"
                           Foreground="Gray"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Padding="12" BorderBrush="#D5DBDB" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10">
            <StackPanel>
                <RadioButton x:Name="PeriodRadio"
                             Content="Пакет за период"
                             FontWeight="SemiBold"
                             Checked="OnModeChanged"/>
                <Grid Margin="22,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="С"/>
                    <DatePicker x:Name="StartDatePicker" Grid.Column="1" Height="28"/>
                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="По"/>
                    <DatePicker x:Name="EndDatePicker" Grid.Column="4" Height="28"/>
                </Grid>
                <CheckBox x:Name="OnlyNotExportedCheckBox"
                          Margin="22,10,0,0"
                          Content="Только невыгруженные документы"
                          IsChecked="True"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="Рекомендация: для первичной сверки выгружайте по одной счет-фактуре, а для рабочего обмена используйте пакет за месяц."
                   Foreground="Gray"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Width="110" Height="32" Margin="0,0,10,0" Content="Выгрузить" Click="OnExportClick"/>
            <Button Width="110" Height="32" Content="Отмена" Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
