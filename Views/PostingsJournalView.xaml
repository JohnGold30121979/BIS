<UserControl x:Class="BIS.ERP.Views.PostingsJournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="📋 Журнал проводок" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Просмотр и анализ бухгалтерских проводок" FontSize="12" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- Панель фильтров -->
        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Период -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <DatePicker x:Name="dpStartDate" Width="120"/>
                    <TextBlock Text="—" VerticalAlignment="Center" Margin="5,0"/>
                    <DatePicker x:Name="dpEndDate" Width="120"/>
                </StackPanel>

                <!-- Быстрый поиск -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Быстрый поиск:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBox x:Name="txtQuickSearch" Width="150" TextChanged="OnQuickSearchChanged"/>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" Margin="5">
                    <Button Content="🔍 Обновить" Click="OnRefreshClick" 
                            Background="#3498DB" Foreground="White" Padding="15,8" Margin="5"/>
                    <Button Content="📊 Обороты по счету" Click="OnTurnoversClick" 
                            Background="#9B59B6" Foreground="White" Padding="15,8" Margin="5"/>
                    <Button Content="📈 Сводные обороты" Click="OnSummaryClick" 
                            Background="#27AE60" Foreground="White" Padding="15,8" Margin="5"/>
                </StackPanel>

                <!-- Детальные фильтры -->
                <Border Grid.Row="1" Grid.ColumnSpan="4" Background="#F8F9FA" CornerRadius="5" Padding="10" Margin="5">
                    <WrapPanel>
                        <TextBox x:Name="txtDebetFilter" Width="100" Margin="5" Tag="Счет Дебет"/>
                        <TextBox x:Name="txtCreditFilter" Width="100" Margin="5" Tag="Счет Кредит"/>
                        <TextBox x:Name="txtOrganizationFilter" Width="150" Margin="5" Tag="Организация"/>
                        <TextBox x:Name="txtEmployeeFilter" Width="120" Margin="5" Tag="Сотрудник"/>
                        <TextBox x:Name="txtDocumentFilter" Width="120" Margin="5" Tag="№ документа"/>
                        <Button Content="✖ Сбросить" Click="OnClearFiltersClick" 
                                Background="#E74C3C" Foreground="White" Padding="10,5" Margin="5"/>
                    </WrapPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Таблица проводок -->
        <DataGrid x:Name="PostingsGrid" Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F8F9FA"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  RowHeight="35"
                  FontSize="12"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling" 
                  SelectionChanged="PostingsGrid_SelectionChanged"
                  MouseDoubleClick="PostingsGrid_MouseDoubleClick">

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3498DB" Opacity="0.3"/>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Документ" Binding="{Binding DocumentNumber}" Width="120"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding DocumentType}" Width="180"/>
                <DataGridTextColumn Header="Дебет" Binding="{Binding DebitAccount}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#2980B9"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Кредит" Binding="{Binding CreditAccount}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#C0392B"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Сумма в сомах" Binding="{Binding Amount, StringFormat=N2}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Сумма в валюте" Binding="{Binding AmountCurrency, StringFormat=N2}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Валюта" Binding="{Binding Currency}" Width="80"/>
                <DataGridTextColumn Header="Организация" Binding="{Binding Organization}" Width="150"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Employee}" Width="120"/>
                <DataGridTextColumn Header="Примечание" Binding="{Binding Note}" Width="*" MinWidth="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="3" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TotalInfo" Text=""/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Подсказка: двойной щелчок по строке открывает подробности проводки." Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
