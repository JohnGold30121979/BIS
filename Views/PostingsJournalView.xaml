<UserControl x:Class="BIS.ERP.Views.PostingsJournalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="📋 Журнал проводок" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Просмотр и анализ бухгалтерских проводок" FontSize="12" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <!-- Панель периода и действий -->
        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Период -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                    <DatePicker x:Name="dpStartDate" Width="120"/>
                    <TextBlock Text="—" VerticalAlignment="Center" Margin="5,0"/>
                    <DatePicker x:Name="dpEndDate" Width="120"/>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="5">
                    <Button Content="🔍 Обновить" Click="OnRefreshClick" 
                            Background="#3498DB" Foreground="White" Padding="15,8" Margin="5"/>
                    <Button Content="📊 Обороты по счету" Click="OnTurnoversClick" 
                            Background="#9B59B6" Foreground="White" Padding="15,8" Margin="5"/>
                    <Button Content="📈 Сводные обороты" Click="OnSummaryClick" 
                            Background="#27AE60" Foreground="White" Padding="15,8" Margin="5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица проводок -->
        <DataGrid x:Name="PostingsGrid" Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F8F9FA"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1" 
                  FontSize="12"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling" 
                  SelectionChanged="PostingsGrid_SelectionChanged"
                  MouseDoubleClick="PostingsGrid_MouseDoubleClick">

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3498DB" Opacity="0.3"/>
                <Style x:Key="ColumnFilterTextBoxStyle" TargetType="TextBox">
                    <Setter Property="MinWidth" Value="70"/>
                    <Setter Property="Height" Value="22"/>
                    <Setter Property="Margin" Value="0,4,0,0"/>
                    <Setter Property="Padding" Value="3,1"/>
                    <Setter Property="FontSize" Value="11"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="110">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Дата"/>
                            <TextBox x:Name="DateFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding DocumentNumber}" Width="130">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Документ"/>
                            <TextBox x:Name="DocumentFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding DocumentType}" Width="180">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Тип"/>
                            <TextBox x:Name="DocumentTypeFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding ModuleName}" Width="140">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Модуль"/>
                            <TextBox x:Name="ModuleFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding DebitAccount}" Width="110">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Дебет"/>
                            <TextBox x:Name="DebitFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#2980B9"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding CreditAccount}" Width="110">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Кредит"/>
                            <TextBox x:Name="CreditFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#C0392B"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Amount, StringFormat=N2}" Width="130">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Сумма в сомах"/>
                            <TextBox x:Name="AmountFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding AmountCurrency, StringFormat=N2}" Width="130">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Сумма в валюте"/>
                            <TextBox x:Name="AmountCurrencyFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Currency}" Width="90">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Валюта"/>
                            <TextBox x:Name="CurrencyFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Organization}" Width="150">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Организация"/>
                            <TextBox x:Name="OrganizationFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Employee}" Width="120">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Сотрудник"/>
                            <TextBox x:Name="EmployeeFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Note}" Width="*" MinWidth="170">
                    <DataGridTextColumn.Header>
                        <StackPanel>
                            <TextBlock Text="Примечание"/>
                            <TextBox x:Name="NoteFilterBox" Style="{StaticResource ColumnFilterTextBoxStyle}" TextChanged="OnColumnFilterChanged"/>
                        </StackPanel>
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="3" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готов"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TotalInfo" Text=""/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Подсказка: двойной щелчок открывает счет-фактуру в просмотре или подробности проводки." Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>