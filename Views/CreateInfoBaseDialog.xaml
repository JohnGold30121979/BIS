<Window x:Class="BIS.ERP.Views.CreateInfoBaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание информационной базы"
        Width="500" 
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#2C3E50" CornerRadius="10" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Border Background="White" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <Border Grid.Row="0" Background="#2C3E50" Padding="20,15" CornerRadius="10,10,0,0">
                    <TextBlock Text="➕ Создание информационной базы" FontSize="18" FontWeight="Bold" 
                               Foreground="White"/>
                </Border>

                <!-- Основное содержимое -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Режим подключения" Foreground="#333" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ModeCombo" Height="35" SelectedIndex="0" Margin="0,0,0,15"
                                  SelectionChanged="OnModeChanged">
                            <ComboBoxItem Content="Создать новую базу" Tag="Create"/>
                            <ComboBoxItem Content="Подключить существующую базу" Tag="Attach"/>
                        </ComboBox>

                        <!-- Название базы -->
                        <TextBlock Text="Название базы" Foreground="#333" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="NameBox" Height="35" Padding="10" FontSize="13" 
                                 Margin="0,0,0,15" TextChanged="OnNameChanged"
                                 Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                 Foreground="#2C3E50" FontWeight="Normal"/>

                        <!-- Расширенные настройки -->
                        <Expander x:Name="SettingsExpander" Header="⚙️ Параметры подключения" IsExpanded="True"
                                  Margin="0,5,0,0" Expanded="OnExpanderExpanded" Collapsed="OnExpanderCollapsed">
                            <StackPanel Margin="0,15,0,0">
                                <TextBlock Text="Сервер (Host)" Foreground="#555" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="HostBox" Text="localhost" Height="40" Padding="10" FontSize="13" 
                                         Margin="0,0,0,12" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                         Foreground="#2C3E50"/>

                                <TextBlock Text="Порт" Foreground="#555" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="PortBox" Text="5432" Height="40
                                         " Padding="10" FontSize="13" 
                                         Margin="0,0,0,12" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                         Foreground="#2C3E50"/>

                                <TextBlock x:Name="DatabaseLabel" Text="Имя базы данных" Foreground="#555" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="DatabaseBox" Height="40" Padding="10" FontSize="13" 
                                         IsEnabled="False" Background="#F0F4F8" BorderBrush="#E0E0E0" BorderThickness="1" 
                                         Margin="0,0,0,12" Foreground="#666"/>

                                <TextBlock Text="Пользователь" Foreground="#555" FontSize="12" Margin="0,0,0,5"/>
                                <TextBox x:Name="UsernameBox" Text="postgres" Height="40" Padding="10" FontSize="13" 
                                         Margin="0,0,0,12" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                         Foreground="#2C3E50"/>

                                <TextBlock Text="Пароль" Foreground="#555" FontSize="12" Margin="0,0,0,5"/>
                                <PasswordBox x:Name="PasswordBox" Height="40" Padding="10" FontSize="13" 
                                             Margin="0,0,0,12" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                             Foreground="#2C3E50"/>

                                <Button x:Name="TestConnectionBtn" Content="🔌 Проверить подключение" 
                                        Height="35" Margin="0,5,0,12" Background="#3498DB" Foreground="White" 
                                        Click="OnTestConnectionClick" Cursor="Hand" FontSize="13"/>

                                <TextBlock x:Name="TestResultText" Foreground="Green" FontSize="12" 
                                           Visibility="Collapsed" Margin="0,0,0,10" TextAlignment="Center" TextWrapping="Wrap"/>

                                <CheckBox x:Name="CreateTestPostingsCheckBox"
                                          Content="Создать тестовые проводки при создании базы"
                                          IsChecked="True"
                                          Margin="0,0,0,12"
                                          Foreground="#555"
                                          FontSize="12"/>
                            </StackPanel>
                        </Expander>

                        <!-- Сообщение об ошибке -->
                        <TextBlock x:Name="ErrorText" Foreground="#E74C3C" FontSize="12" 
                                   Visibility="Collapsed" Margin="0,15,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Кнопки -->
                <Border Grid.Row="2" Background="#F0F4F8" Padding="15" CornerRadius="0,0,10,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CreateButton" Content="Создать" Width="110" Height="36"
                                Margin="0,0,10,0" Background="#27AE60" Foreground="White" IsEnabled="False"
                                Click="OnCreateClick" Cursor="Hand" FontSize="13"/>
                        <Button x:Name="CancelButton" Content="Отмена" Width="110" Height="36"
                                Background="#95A5A6" Foreground="White"
                                Click="OnCancelClick" Cursor="Hand" FontSize="13"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
