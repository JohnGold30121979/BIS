<Window x:Class="BIS.ERP.Views.CreateInfoBaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание информационной базы"
        Width="500" Height="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="White" CornerRadius="10" Padding="20">
        <StackPanel>
            <!-- Заголовок -->
            <TextBlock Text="Создание информационной базы" FontSize="20" FontWeight="Bold" 
                       Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Название базы -->
            <TextBlock Text="Название базы" Foreground="#333" Margin="0,0,0,5"/>
            <TextBox x:Name="NameBox" Height="35" Padding="10" Margin="0,0,0,15"
                     TextChanged="OnNameChanged"/>

            <!-- Тип базы -->
            <TextBlock Text="Тип базы" Foreground="#333" Margin="0,0,0,5"/>
            <ComboBox x:Name="TypeCombo" Height="35" Margin="0,0,0,15" SelectedIndex="0">
                <ComboBoxItem Content="💰 Финансы" Tag="Finance"/>
                <ComboBoxItem Content="📦 Учет ТМЦ" Tag="Inventory"/>
                <ComboBoxItem Content="👥 Зарплата и кадры" Tag="Salary"/>
                <ComboBoxItem Content="⚙️ Основные средства" Tag="Assets"/>
                <ComboBoxItem Content="🌐 Универсальная" Tag="Universal"/>
            </ComboBox>

            <!-- Расширенные настройки -->
            <Expander Header="⚙️ Параметры подключения" Margin="0,5,0,15" IsExpanded="False">
                <StackPanel Margin="0,10,0,0">
                    <TextBlock Text="Сервер (Host)" Margin="0,0,0,5"/>
                    <TextBox x:Name="HostBox" Text="localhost" Height="35" Padding="10" Margin="0,0,0,10"/>

                    <TextBlock Text="Порт" Margin="0,0,0,5"/>
                    <TextBox x:Name="PortBox" Text="5432" Height="35" Padding="10" Margin="0,0,0,10"/>

                    <TextBlock Text="Имя базы данных (создастся автоматически)" Margin="0,0,0,5"/>
                    <TextBox x:Name="DatabaseBox" Height="35" Padding="10" 
                             IsEnabled="False" Background="#F0F0F0" Margin="0,0,0,10"/>

                    <TextBlock Text="Пользователь" Margin="0,0,0,5"/>
                    <TextBox x:Name="UsernameBox" Text="postgres" Height="35" Padding="10" Margin="0,0,0,10"/>

                    <TextBlock Text="Пароль" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox" Height="35" Padding="10" Margin="0,0,0,10"/>

                    <Button x:Name="TestConnectionBtn" Content="🔌 Проверить подключение" 
                            Height="35" Margin="0,5,0,10" Background="#3498DB" Foreground="White"
                            Click="OnTestConnectionClick"/>

                    <TextBlock x:Name="TestResultText" Foreground="Green" 
                               Visibility="Collapsed" Margin="0,0,0,10" TextAlignment="Center"/>
                </StackPanel>
            </Expander>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="ErrorText" Foreground="Red" 
                       Visibility="Collapsed" Margin="0,10" TextWrapping="Wrap"/>

            <!-- Кнопки -->
            <Border Height="1" Background="#E0E0E0" Margin="0,10,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Отмена" Width="90" Height="35" 
                        Margin="0,0,10,0" Background="#95A5A6" Foreground="White"
                        Click="OnCancelClick"/>
                <Button x:Name="CreateButton" Content="Создать" Width="90" Height="35" 
                        Background="#27AE60" Foreground="White" IsEnabled="False"
                        Click="OnCreateClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>