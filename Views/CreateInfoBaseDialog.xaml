<Window x:Class="BIS.ERP.Views.CreateInfoBaseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание информационной базы"
        Width="450" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#2C3E50">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style TargetType="TextBox" x:Key="DefaultTextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="PasswordBox" x:Key="DefaultPasswordBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="DefaultComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="8" Margin="10">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" Text="Создание информационной базы" 
                       FontSize="18" FontWeight="Bold" 
                       Foreground="#2C3E50" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <!-- Название базы -->
            <TextBlock Grid.Row="1" Text="Название базы"/>
            <TextBox x:Name="NameBox" Grid.Row="2" 
                     Style="{StaticResource DefaultTextBox}"
                     TextChanged="OnNameChanged"/>

            <!-- Тип базы -->
            <TextBlock Grid.Row="3" Text="Тип базы"/>
            <ComboBox x:Name="TypeCombo" Grid.Row="4" 
                      Style="{StaticResource DefaultComboBox}"
                      SelectedIndex="0">
                <ComboBoxItem Content="💰 Финансы" Tag="Finance"/>
                <ComboBoxItem Content="📦 Учет ТМЦ" Tag="Inventory"/>
                <ComboBoxItem Content="👥 Зарплата и кадры" Tag="Salary"/>
                <ComboBoxItem Content="⚙️ Основные средства" Tag="Assets"/>
            </ComboBox>

            <!-- Расширенные настройки (аккордеон) -->
            <Expander Grid.Row="5" Header="⚙️ Параметры подключения" 
                      Margin="0,5,0,10" IsExpanded="False">
                <StackPanel Margin="0,10,0,0">
                    <!-- Сервер -->
                    <TextBlock Text="Сервер (Host)" Margin="0,0,0,5"/>
                    <TextBox x:Name="HostBox" 
                             Style="{StaticResource DefaultTextBox}" 
                             Text="localhost"/>

                    <!-- Порт -->
                    <TextBlock Text="Порт" Margin="0,0,0,5"/>
                    <TextBox x:Name="PortBox" 
                             Style="{StaticResource DefaultTextBox}" 
                             Text="5432"/>

                    <!-- Имя БД (автоматическое) -->
                    <TextBlock Text="Имя базы данных (создастся автоматически)" Margin="0,0,0,5"/>
                    <TextBox x:Name="DatabaseBox" 
                             Style="{StaticResource DefaultTextBox}" 
                             IsEnabled="False" 
                             Background="#F0F0F0"/>

                    <!-- Пользователь -->
                    <TextBlock Text="Пользователь" Margin="0,0,0,5"/>
                    <TextBox x:Name="UsernameBox" 
                             Style="{StaticResource DefaultTextBox}" 
                             Text="postgres"/>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox" 
                                 Style="{StaticResource DefaultPasswordBox}"/>

                    <!-- Кнопка проверки подключения -->
                    <Button x:Name="TestConnectionBtn" 
                            Content="🔌 Проверить подключение" 
                            Height="32" Margin="0,5,0,10"
                            Background="#4CAF50" Foreground="White"
                            Click="OnTestConnectionClick"/>

                    <TextBlock x:Name="TestResultText" 
                               Foreground="Green" 
                               Margin="0,0,0,10" 
                               Visibility="Collapsed"/>
                </StackPanel>
            </Expander>

            <!-- Ошибка -->
            <TextBlock x:Name="ErrorText" Grid.Row="6" 
                       Foreground="Red" 
                       Margin="0,10,0,0" 
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="8" Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="0,20,0,0">
                <Button x:Name="CancelBtn" 
                        Content="Отмена" 
                        Width="90" Height="35" 
                        Margin="0,0,10,0"
                        Background="#95A5A6" 
                        Foreground="White"
                        Click="OnCancelClick"/>
                <Button x:Name="CreateBtn" 
                        Content="Создать" 
                        Width="90" Height="35"
                        Background="#2C3E50" 
                        Foreground="White"
                        IsEnabled="False"
                        Click="OnCreateClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>