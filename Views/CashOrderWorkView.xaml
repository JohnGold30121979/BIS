<UserControl x:Class="BIS.ERP.Views.CashOrderWorkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock x:Name="DescriptionText" FontSize="12" Foreground="Gray"/>
        </StackPanel>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="AddButton" Content="➕ Добавить" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#27AE60" Foreground="White" Click="OnAddClick"/>
            <Button x:Name="EditButton" Content="✏️ Редактировать" Width="120" Height="35" Margin="0,0,10,0"
                    Background="#3498DB" Foreground="White" IsEnabled="False" Click="OnEditClick"/>
            <Button x:Name="DeleteButton" Content="🗑️ Удалить" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#E74C3C" Foreground="White" IsEnabled="False" Click="OnDeleteClick"/>
            <Button x:Name="PostButton" Content="✅ Провести" Width="100" Height="35" Margin="0,0,10,0"
                    Background="#9B59B6" Foreground="White" IsEnabled="False" Click="OnPostClick"/>
            <Button x:Name="RefreshButton" Content="🔄 Обновить" Width="100" Height="35"
                    Background="#95A5A6" Foreground="White" Click="OnRefreshClick"/>
        </StackPanel>

        <!-- Таблица -->
        <DataGrid x:Name="DataGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionChanged="OnSelectionChanged"
                  AlternatingRowBackground="#F5F5F5" BorderBrush="#BDC3C7" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер" Binding="{Binding DocNumber}" Width="100"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding DocDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Организация" Binding="{Binding OrganizationName}" Width="150"/>
                <DataGridTextColumn Header="Валюта" Binding="{Binding CurrencyName}" Width="90"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding EmployeeName}" Width="150"/>
                <DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="150"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount}" Width="100"/>
                <DataGridTextColumn Header="Основание" Binding="{Binding Basis}" Width="150"/>
                <DataGridTextColumn Header="Корр. счет" Binding="{Binding CorrespondentAccountName}" Width="120"/>
                <DataGridTextColumn Header="Примечание" Binding="{Binding Description}" Width="150"/>
                <DataGridTextColumn Header="Проведён" Binding="{Binding IsPosted}" Width="80"/>
                <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt}" Width="150"/>
                <DataGridTextColumn Header="Дата изменения" Binding="{Binding UpdatedAt}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готово" Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>
