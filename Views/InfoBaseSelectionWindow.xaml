<!-- Views/InfoBaseSelectionWindow.xaml -->
<Window x:Class="BIS.ERP.Views.InfoBaseSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запуск BIS ERP"
        Height="550" Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="400" MinWidth="600">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#F0F4F8" Padding="15,10">
            <TextBlock Text="BIS ERP" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
        </Border>

        <!-- Основное содержимое -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - список инфобаз -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Информационные базы" 
                               FontWeight="Bold" Margin="5,0,5,10"/>

                    <!-- Прогресс-бар -->
                    <ProgressBar x:Name="LoadingProgress" DockPanel.Dock="Top" 
                                 Height="3" IsIndeterminate="True" 
                                 Visibility="Collapsed" Margin="0,0,0,5"/>

                    <ListBox x:Name="InfoBasesList" BorderThickness="0"
                         SelectionChanged="OnInfoBaseSelected">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="0,2">
                                    <StackPanel>
                                        <!-- Показываем DisplayName вместо Name -->
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{Binding TypeName}" FontSize="11" Foreground="#666"/>
                                        <TextBlock Text="{Binding DatabaseName}" FontSize="10" Foreground="#999"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Пустое сообщение -->
                    <TextBlock x:Name="EmptyTextBlock" Text="Нет информационных баз" 
                               Foreground="#666" HorizontalAlignment="Center" 
                               Margin="0,50,0,0" Visibility="Collapsed"/>
                </DockPanel>
            </Border>

            <!-- Правая панель - настройки -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Margin="10,0,0,0">
                <StackPanel Margin="15">
                    <TextBlock Text="BIS Выбор параметров" FontSize="16" FontWeight="Bold" 
                               Margin="0,0,0,15"/>

                    <Button x:Name="WorkModeButton" Content="Рабочий режим" 
                            Height="40" Margin="0,5" Click="OnWorkModeClick"
                            Background="#3498DB" Foreground="White" FontWeight="Bold"/>

                    <Button x:Name="ConfigModeButton" Content="Конфигуратор" 
                            Height="40" Margin="0,5" Click="OnConfigModeClick"
                            Background="#3498DB" Foreground="White" FontWeight="Bold"/>

                    <Separator Margin="0,15"/>

                    <Button x:Name="AddButton" Content="Добавить..." 
                            Height="35" Margin="0,5" Click="OnAddClick"
                            Background="Transparent" BorderBrush="#3498DB" BorderThickness="1"/>

                    <Button x:Name="EditButton" Content="Изменить..." 
                            Height="35" Margin="0,5" Click="OnEditClick"
                            Background="Transparent" BorderBrush="#3498DB" BorderThickness="1"
                            IsEnabled="False"/>

                    <Button x:Name="DeleteButton" Content="Удалить" 
                            Height="35" Margin="0,5" Click="OnDeleteClick"
                            Background="Transparent" BorderBrush="#E74C3C" BorderThickness="1"
                            Foreground="#E74C3C" IsEnabled="False"/>

                    <Button x:Name="SettingsButton" Content="Настройка..." 
                            Height="35" Margin="0,5" Click="OnSettingsClick"
                            Background="Transparent" BorderBrush="#95A5A6" BorderThickness="1"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="#F0F4F8" Padding="10,8">
            <Grid>
                <TextBlock x:Name="ConnectionPathText" Text="Выберите информационную базу" 
                           Foreground="#666" FontSize="11" VerticalAlignment="Center"/>
                <Button x:Name="ExitButton" Content="Выход" Width="80" Height="30" 
                        HorizontalAlignment="Right" Click="OnExitClick"
                        Background="#E74C3C" Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>