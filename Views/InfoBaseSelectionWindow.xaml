<!-- Views/InfoBaseSelectionWindow.xaml -->
<Window x:Class="BIS.ERP.Views.InfoBaseSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BIS.ERP.Converters"
        Title="Запуск BIS ERP"
        Height="550" Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="400" MinWidth="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ByteArrayToImageSourceConverter x:Key="ByteArrayToImageSourceConverter"/>
    </Window.Resources>

    <Border Background="{DynamicResource AppBrandShellBackgroundBrush}" CornerRadius="10" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="{DynamicResource AppBrandHeaderBackgroundBrush}" CornerRadius="10,10,0,0" Padding="20,15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Width="28" Height="28" CornerRadius="7"
                                Background="{DynamicResource AppAccentBrush}"
                                Margin="0,0,8,0">
                            <Grid>
                                <Image x:Name="SystemLogoImage" Stretch="UniformToFill" Visibility="Collapsed"/>
                                <TextBlock x:Name="SystemIconText" FontSize="18"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppBrandIconForegroundBrush}"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="SystemNameText" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource AppBrandTitleForegroundBrush}"/>
                    </StackPanel>
                    <TextBlock Text="Выбор информационной базы" FontSize="12"
                               Foreground="{DynamicResource AppBrandSubtitleForegroundBrush}" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Основное содержимое -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="240"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель - список инфобаз -->
                <Border Grid.Column="0" Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="8" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📊 Информационные базы"
                                   FontWeight="Bold" Margin="5,0,5,10" FontSize="13"
                                   Foreground="{DynamicResource AppBodyTextBrush}"/>

                        <!-- Прогресс-бар -->
                        <ProgressBar x:Name="LoadingProgress" Grid.Row="1"
                                     Height="3" IsIndeterminate="True"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                     Margin="0,0,0,5"/>

                        <Grid Grid.Row="2">
                            <ListBox x:Name="InfoBasesList"
                                 BorderThickness="0"
                                 Background="{DynamicResource AppInputBackgroundBrush}"
                                 HorizontalContentAlignment="Stretch"
                                 ItemsSource="{Binding InfoBases}"
                                 SelectedItem="{Binding SelectedInfoBase, Mode=TwoWay}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,3"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemBorder"
                                                        Background="{DynamicResource AppReadOnlyBackgroundBrush}"
                                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Stretch"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="10" HorizontalAlignment="Stretch">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Круглая иконка -->
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" 
                                    Background="{DynamicResource AppAccentBrush}" Margin="0,0,12,0">
                                                <Grid>
                                                    <Ellipse Visibility="{Binding HasLogoImage, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Ellipse.Fill>
                                                            <ImageBrush ImageSource="{Binding LogoImage, Converter={StaticResource ByteArrayToImageSourceConverter}}"
                                                                        Stretch="UniformToFill"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding DisplayIcon}" FontSize="20"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="{Binding UsesTextIcon, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Информация о базе -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" 
                                           Foreground="{DynamicResource AppBodyTextBrush}"/>
                                                <TextBlock Text="Информационная база" FontSize="11" 
                                           Foreground="{DynamicResource AppSecondaryTextBrush}" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding PatchVersionDisplay}" FontSize="11"
                                           Foreground="{DynamicResource AppAccentBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                            <!-- Пустое сообщение -->
                            <TextBlock x:Name="EmptyTextBlock" Text="Нет информационных баз"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Top"
                                       Margin="0,50,0,0"
                                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="12"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              ShowsPreview="True"
                              ResizeBehavior="PreviousAndNext"
                              ResizeDirection="Columns">
                    <GridSplitter.Template>
                        <ControlTemplate TargetType="GridSplitter">
                            <Grid Background="Transparent">
                                <Border Width="2"
                                        HorizontalAlignment="Center"
                                        Background="{DynamicResource AppBorderBrush}"
                                        CornerRadius="1"/>
                            </Grid>
                        </ControlTemplate>
                    </GridSplitter.Template>
                </GridSplitter>

                <!-- Правая панель - настройки -->
                <Border Grid.Column="2" Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Margin="15">
                        <TextBlock Text="⚙️ Режим работы" FontSize="16" FontWeight="Bold" 
                                   Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,15"/>

                        <Button x:Name="WorkModeButton" Content="💼 Рабочий режим" 
                                Height="40" Margin="0,5" Command="{Binding StartWorkModeCommand}"
                                Background="#27AE60" Foreground="White" FontWeight="Bold"
                                Cursor="Hand"/>

                        <Button x:Name="ConfigModeButton" Content="⚙️ Конфигуратор" 
                                Height="40" Margin="0,5" Command="{Binding StartConfigModeCommand}"
                                Background="#3498DB" Foreground="White" FontWeight="Bold"
                                Cursor="Hand"/>

                        <Separator Margin="0,15" Background="{DynamicResource AppBorderBrush}" Height="1"/>

                        <TextBlock Text="📁 Управление базами" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="{DynamicResource AppBodyTextBrush}" Margin="0,0,0,10"/>

                        <Button x:Name="AddButton" Content="➕ Добавить..." 
                                Height="35" Margin="0,5" Command="{Binding AddCommand}"
                                Background="Transparent" BorderBrush="#27AE60" BorderThickness="1"
                                Foreground="#27AE60" Cursor="Hand"/>

                        <Button x:Name="EditButton" Content="✏️ Изменить..." 
                                Height="35" Margin="0,5" Command="{Binding EditCommand}"
                                Background="Transparent" BorderBrush="#3498DB" BorderThickness="1"
                                Foreground="#3498DB" Cursor="Hand"/>

                        <Button x:Name="DeleteButton" Content="🗑️ Удалить" 
                                Height="35" Margin="0,5" Command="{Binding DeleteCommand}"
                                Background="Transparent" BorderBrush="#E74C3C" BorderThickness="1"
                                Foreground="#E74C3C" Cursor="Hand"/>

                        <Button x:Name="SettingsButton" Content="🔧 Настройка..." 
                                Height="35" Margin="0,5" Command="{Binding SettingsCommand}"
                                Background="Transparent" BorderBrush="#9B59B6" BorderThickness="1"
                                Foreground="#9B59B6" Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Нижняя панель -->
            <Border Grid.Row="2" Background="{DynamicResource AppBrandHeaderBackgroundBrush}" CornerRadius="0,0,10,10" Padding="10,8">
                <Grid>
                    <TextBlock x:Name="ConnectionPathText" Text="{Binding ConnectionPath}" 
                               Foreground="{DynamicResource AppBrandStatusForegroundBrush}" FontSize="11" VerticalAlignment="Center"/>
                    <Button x:Name="ExitButton" Content="🚪 Выход" Width="80" Height="30" 
                            HorizontalAlignment="Right" Command="{Binding ExitCommand}"
                            Background="#E74C3C" Foreground="White" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
