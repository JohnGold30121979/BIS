<!-- Views/InfoBaseSelectionWindow.xaml -->
<Window x:Class="BIS.ERP.Views.InfoBaseSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запуск BIS ERP"
        Height="550" Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="400" MinWidth="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#2C3E50" CornerRadius="10" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" Background="#1A252F" CornerRadius="10,10,0,0" Padding="20,15">
                <StackPanel>
                    <TextBlock Text="BIS ERP" FontSize="22" FontWeight="Bold" Foreground="White" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Выбор информационной базы" FontSize="12" Foreground="#7F8C8D" 
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Основное содержимое -->
            <Grid Grid.Row="1" Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель - список инфобаз -->
                <!-- Левая панель - список инфобаз -->
                <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="8" Padding="10">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="📊 Информационные базы" 
                   FontWeight="Bold" Margin="5,0,5,10" FontSize="13" Foreground="#2C3E50"/>

                        <!-- Прогресс-бар -->
                        <ProgressBar x:Name="LoadingProgress" DockPanel.Dock="Top" 
                     Height="3" IsIndeterminate="True" 
                     Visibility="Collapsed" Margin="0,0,0,5"/>

                        <ListBox x:Name="InfoBasesList" BorderThickness="0"
                 SelectionChanged="OnInfoBaseSelected">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,3" Background="#F8F9FA" CornerRadius="8"
                            BorderBrush="#E0E0E0" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Круглая иконка -->
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" 
                                    Background="#3498DB" Margin="0,0,12,0">
                                                <TextBlock Text="📊" FontSize="20" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Информация о базе -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" 
                                           Foreground="#2C3E50"/>
                                                <TextBlock Text="Информационная база" FontSize="11" 
                                           Foreground="#7F8C8D" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Пустое сообщение -->
                        <TextBlock x:Name="EmptyTextBlock" Text="Нет информационных баз" 
                   Foreground="#95A5A6" HorizontalAlignment="Center" 
                   Margin="0,50,0,0" Visibility="Collapsed"/>
                    </DockPanel>
                </Border>

                <!-- Правая панель - настройки -->
                <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="8" Margin="10,0,0,0">
                    <StackPanel Margin="15">
                        <TextBlock Text="⚙️ Режим работы" FontSize="16" FontWeight="Bold" 
                                   Foreground="#2C3E50" Margin="0,0,0,15"/>

                        <Button x:Name="WorkModeButton" Content="💼 Рабочий режим" 
                                Height="40" Margin="0,5" Click="OnWorkModeClick"
                                Background="#27AE60" Foreground="White" FontWeight="Bold"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="ConfigModeButton" Content="⚙️ Конфигуратор" 
                                Height="40" Margin="0,5" Click="OnConfigModeClick"
                                Background="#3498DB" Foreground="White" FontWeight="Bold"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Separator Margin="0,15" Background="#E0E0E0" Height="1"/>

                        <TextBlock Text="📁 Управление базами" FontSize="13" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,10"/>

                        <Button x:Name="AddButton" Content="➕ Добавить..." 
                                Height="35" Margin="0,5" Click="OnAddClick"
                                Background="Transparent" BorderBrush="#27AE60" BorderThickness="1"
                                Foreground="#27AE60" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="EditButton" Content="✏️ Изменить..." 
                                Height="35" Margin="0,5" Click="OnEditClick"
                                Background="Transparent" BorderBrush="#3498DB" BorderThickness="1"
                                Foreground="#3498DB" IsEnabled="False" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="DeleteButton" Content="🗑️ Удалить" 
                                Height="35" Margin="0,5" Click="OnDeleteClick"
                                Background="Transparent" BorderBrush="#E74C3C" BorderThickness="1"
                                Foreground="#E74C3C" IsEnabled="False" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="SettingsButton" Content="🔧 Настройка..." 
                                Height="35" Margin="0,5" Click="OnSettingsClick"
                                Background="Transparent" BorderBrush="#9B59B6" BorderThickness="1"
                                Foreground="#9B59B6" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Нижняя панель -->
            <Border Grid.Row="2" Background="#1A252F" CornerRadius="0,0,10,10" Padding="10,8">
                <Grid>
                    <TextBlock x:Name="ConnectionPathText" Text="📁 Выберите информационную базу" 
                               Foreground="#7F8C8D" FontSize="11" VerticalAlignment="Center"/>
                    <Button x:Name="ExitButton" Content="🚪 Выход" Width="80" Height="30" 
                            HorizontalAlignment="Right" Click="OnExitClick"
                            Background="#E74C3C" Foreground="White" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>