<Window x:Class="BIS.ERP.Views.PdfPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Предпросмотр печатной формы"
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{DynamicResource AppHeaderBackgroundBrush}" Padding="10">
            <TextBlock Text="📄 Предпросмотр печатной формы" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="{DynamicResource AppPrimaryTextBrush}"/>
        </Border>

        <!-- PDF Preview Host -->
        <Border Grid.Row="1" Margin="10" Padding="24"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                Background="White">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="620">
                <TextBlock Text="PDF сформирован"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock x:Name="PreviewStatusText"
                           Text="Документ будет открыт во внешнем просмотрщике PDF."
                           FontSize="14"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="#5D6D7E"
                           Margin="0,0,0,18"/>
                <Button Content="Открыть PDF"
                        Width="150"
                        Height="36"
                        Background="#34495E"
                        Foreground="White"
                        Click="OnOpenClick"/>
            </StackPanel>
        </Border>

        <!-- Панель кнопок -->
        <Border Grid.Row="2" Background="{DynamicResource AppHeaderBackgroundBrush}" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 Сохранить PDF" Width="120" Height="35" Margin="5"
                        Background="#27AE60" Foreground="White" Click="OnSaveClick"
                        Cursor="Hand"/>
                <Button Content="🖨 Печать" Width="100" Height="35" Margin="5"
                        Background="#3498DB" Foreground="White" Click="OnPrintClick"
                        Cursor="Hand"/>
                <Button Content="❌ Закрыть" Width="100" Height="35" Margin="5"
                        Background="#E74C3C" Foreground="White" Click="OnCloseClick"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
