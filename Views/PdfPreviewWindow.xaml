<Window x:Class="BIS.ERP.Views.PdfPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Предпросмотр печатной формы"
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="{DynamicResource AppHeaderBackgroundBrush}" Padding="10">
            <TextBlock Text="📄 Предпросмотр печатной формы" 
                       FontSize="16" FontWeight="Bold" 
                       Foreground="{DynamicResource AppPrimaryTextBrush}"/>
        </Border>

        <!-- PDF Viewer -->
        <WebBrowser x:Name="PdfViewer" Grid.Row="1" Margin="10"/>

        <!-- Панель кнопок -->
        <Border Grid.Row="2" Background="{DynamicResource AppHeaderBackgroundBrush}" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="💾 Сохранить PDF" Width="120" Height="35" Margin="5"
                        Background="#27AE60" Foreground="White" Click="OnSaveClick"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="🖨 Печать" Width="100" Height="35" Margin="5"
                        Background="#3498DB" Foreground="White" Click="OnPrintClick"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="❌ Закрыть" Width="100" Height="35" Margin="5"
                        Background="#E74C3C" Foreground="White" Click="OnCloseClick"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>