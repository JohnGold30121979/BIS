<UserControl x:Class="BIS.ERP.Views.DynamicDocumentWorkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <Border Grid.Row="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddButton" Content="➕ Добавить" Click="OnAddClick" 
                        Background="#4CAF50" Foreground="White" Padding="15,8" Margin="0,0,10,0"
                        Cursor="Hand" FontWeight="Bold"/>
                <Button x:Name="EditButton" Content="✏️ Редактировать" Click="OnEditClick" 
                        Background="#2196F3" Foreground="White" Padding="15,8" Margin="0,0,10,0"
                        Cursor="Hand"/>
                <Button x:Name="DeleteButton" Content="🗑️ Удалить" Click="OnDeleteClick" 
                        Background="#F44336" Foreground="White" Padding="15,8" Margin="0,0,10,0"
                        Cursor="Hand"/>
                <Button Content="🔄 Обновить" Click="OnRefreshClick" 
                        Background="#9B59B6" Foreground="White" Padding="15,8"
                        Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- Таблица данных -->
        <DataGrid x:Name="DataGrid" Grid.Row="1"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#F8F9FA"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  RowHeight="35"
                  FontSize="13"
                  SelectionChanged="OnSelectionChanged">
            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3498DB" Opacity="0.3"/>
            </DataGrid.Resources>
        </DataGrid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="2" Margin="0,5,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Готово"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>