<Window x:Class="BIS.ERP.Views.DbfImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Импорт из DBF"
        Height="650" Width="850"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Импорт из DBF" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <!-- Выбор файла -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilePathBox" Grid.Column="0" Height="35" Padding="10" IsReadOnly="True" Background="#F8F9FA"/>
            <Button x:Name="BrowseButton" Grid.Column="1" Content="Обзор..." Width="80" Height="35" Margin="10,0,0,0"
                    Background="#3498DB" Foreground="White" Click="OnBrowseClick"/>
        </Grid>

        <!-- Информация о файле -->
        <Border Grid.Row="2" Background="#F0F4F8" CornerRadius="5" Padding="10" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock x:Name="FileInfoText" Text="Файл не выбран" FontWeight="SemiBold"/>
                <TextBlock x:Name="RecordInfoText" Text="" Foreground="#666"/>
            </StackPanel>
        </Border>

        <!-- Данные -->
        <DataGrid x:Name="DataGrid" Grid.Row="3" AutoGenerateColumns="True" 
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <!-- Прогресс -->
        <ProgressBar x:Name="ProgressBar" Grid.Row="4" Height="20" Margin="0,15,0,10" Visibility="Collapsed"/>
        <TextBlock x:Name="StatusTextBlock" Grid.Row="4" Foreground="#666" Margin="0,15,0,10" Visibility="Collapsed"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="ImportButton" Content="Импортировать" Width="120" Height="35" Margin="0,0,10,0"
                    Background="#27AE60" Foreground="White" IsEnabled="False" Click="OnImportClick"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="90" Height="35" 
                    Background="#95A5A6" Foreground="White" Click="OnCloseClick"/>
        </StackPanel>
    </Grid>
</Window>