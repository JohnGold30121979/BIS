<Window x:Class="BIS.ERP.Views.FrxImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Импорт отчетов из FoxPro (FRX)"
        Height="483" Width="596"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="White" Padding="20" CornerRadius="10">
        <StackPanel>
            <TextBlock Text="📁 Импорт FRX файлов" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

            <Button x:Name="SelectFilesButton" Content="➕ Выбрать FRX файлы" 
                    Width="180" Height="35" Click="OnSelectFilesClick"
                    Background="#3498DB" Foreground="White" Cursor="Hand"/>

            <ListBox x:Name="FilesList" Height="150" Margin="0,10,0,10"
                     SelectionChanged="OnFileSelected">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8" Margin="0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding FileName}" FontWeight="Bold"/>
                                <TextBlock Text=" - " Margin="5,0"/>
                                <TextBlock Text="{Binding Size}" Foreground="#666"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GroupBox Header="Предпросмотр" Margin="0,10">
                <ScrollViewer MaxHeight="120">
                    <TextBlock x:Name="PreviewText" TextWrapping="Wrap" FontFamily="Courier New" FontSize="11"/>
                </ScrollViewer>
            </GroupBox>

            <ProgressBar x:Name="ProgressBar" Height="15" Margin="0,10" Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText" Foreground="#666" Margin="0,5"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="ImportButton" Content="📥 Импортировать" Width="120" Height="35"
                        Background="#27AE60" Foreground="White" IsEnabled="False"
                        Click="OnImportClick" Margin="0,0,10,0" Cursor="Hand"/>
                <Button x:Name="CancelButton" Content="Отмена" Width="80" Height="35"
                        Background="#95A5A6" Foreground="White" Click="OnCancelClick" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>