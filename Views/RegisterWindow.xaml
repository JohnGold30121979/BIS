<Window x:Class="BIS.ERP.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:BIS.ERP.Behaviors"
        xmlns:converters="clr-namespace:BIS.ERP.Converters"
        Title="Регистрация" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Border Background="#2C3E50" CornerRadius="10" Margin="10">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Регистрация" FontSize="24" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Grid.Row="1" Text="Логин" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="LoginBox" Grid.Row="2" Height="35" Padding="10" Margin="0,0,0,15"
                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="3" Text="Полное имя" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="FullNameBox" Grid.Row="4" Height="35" Padding="10" Margin="0,0,0,15"
                     Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="5" Text="Email" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailBox" Grid.Row="6" Height="35" Padding="10" Margin="0,0,0,15"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="7" Text="Пароль" Foreground="White" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="8" Height="35" Padding="10" Margin="0,0,0,15"
                         behaviors:PasswordBoxBindingBehavior.BindPassword="True"
                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="9" Text="Подтверждение пароля" Foreground="White" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="10" Height="35" Padding="10" Margin="0,0,0,20"
                         behaviors:PasswordBoxBindingBehavior.BindPassword="True"
                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock x:Name="ErrorText" Grid.Row="11" Text="{Binding ErrorMessage}" Foreground="#E74C3C" FontSize="12" 
                       TextAlignment="Center" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,10"/>

            <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="RegisterButton" Content="Зарегистрироваться" Width="140" Height="40"
                        Background="#3498DB" Foreground="White" Command="{Binding RegisterCommand}" Margin="0,0,10,0"/>
                <Button x:Name="BackButton" Content="Назад" Width="100" Height="40"
                        Background="Transparent" Foreground="White" 
                        BorderBrush="#3498DB" BorderThickness="1" Command="{Binding BackCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
