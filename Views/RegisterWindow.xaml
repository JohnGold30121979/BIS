<Window x:Class="BIS.ERP.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:BIS.ERP.Behaviors"
        xmlns:converters="clr-namespace:BIS.ERP.Converters"
        Title="Регистрация" 
        Height="660" Width="520"
        MinHeight="560"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Border Background="#2C3E50" CornerRadius="10" Margin="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Регистрация" FontSize="24" FontWeight="Bold" 
                       Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>

            <TextBlock Grid.Row="1" Text="{Binding SelectedInfoBaseText}" FontSize="13"
                       Foreground="#B6E0FE" HorizontalAlignment="Center"
                       TextAlignment="Center" TextWrapping="Wrap"
                       Visibility="{Binding HasSelectedInfoBase, Converter={StaticResource BoolToVisibilityConverter}}"
                       Margin="0,0,0,14"/>

            <TextBlock Grid.Row="2" Text="Логин" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="LoginBox" Grid.Row="3" Height="32" Padding="10,6" Margin="0,0,0,10"
                     PreviewKeyDown="OnLoginPreviewKeyDown"
                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="4" Text="Полное имя" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="FullNameBox" Grid.Row="5" Height="32" Padding="10,6" Margin="0,0,0,10"
                     PreviewKeyDown="OnFullNamePreviewKeyDown"
                     Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="6" Text="Email" Foreground="White" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailBox" Grid.Row="7" Height="32" Padding="10,6" Margin="0,0,0,10"
                     PreviewKeyDown="OnEmailPreviewKeyDown"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="8" Text="Роль" Foreground="White" Margin="0,0,0,5"/>
            <ComboBox x:Name="RoleBox" Grid.Row="9" Height="32" Padding="8,4" Margin="0,0,0,10"
                      ItemsSource="{Binding AvailableRoles}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Role"
                      SelectedValue="{Binding SelectedRole, Mode=TwoWay}"
                      PreviewKeyDown="OnRolePreviewKeyDown"/>

            <TextBlock Grid.Row="10" Text="Пароль" Foreground="White" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="11" Height="32" Padding="10,6" Margin="0,0,0,10"
                         PreviewKeyDown="OnPasswordPreviewKeyDown"
                         behaviors:PasswordBoxBindingBehavior.BindPassword="True"
                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="12" Text="Подтверждение пароля" Foreground="White" Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="13" Height="32" Padding="10,6" Margin="0,0,0,12"
                         PreviewKeyDown="OnConfirmPasswordPreviewKeyDown"
                         behaviors:PasswordBoxBindingBehavior.BindPassword="True"
                         behaviors:PasswordBoxBindingBehavior.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock x:Name="ErrorText" Grid.Row="14" Text="{Binding ErrorMessage}" Foreground="#E74C3C" FontSize="12" 
                       TextAlignment="Center" Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,10"/>

            <StackPanel Grid.Row="15" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button x:Name="RegisterButton" Content="Зарегистрироваться" Width="140" Height="40"
                        Background="#3498DB" Foreground="White" Command="{Binding RegisterCommand}" Margin="0,0,10,0"
                        IsDefault="True"/>
                <Button x:Name="BackButton" Content="Назад" Width="100" Height="40"
                        Background="Transparent" Foreground="White" 
                        BorderBrush="#3498DB" BorderThickness="1" Command="{Binding BackCommand}"
                        IsCancel="True"/>
            </StackPanel>
            </Grid>
        </ScrollViewer>
    </Border>
</Window>
