<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Светлая тема -->
    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="AppSidebarBackgroundBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#1A252F"/>
    <SolidColorBrush x:Key="AppContentBackgroundBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppAlternateRowBrush" Color="#F4F7F9"/>
    <SolidColorBrush x:Key="AppBorderBrush" Color="#D7DEE5"/>
    <SolidColorBrush x:Key="AppReadOnlyBackgroundBrush" Color="#E9EDF1"/>
    <SolidColorBrush x:Key="AppBodyTextBrush" Color="#243447"/>
    <SolidColorBrush x:Key="AppTableHeaderBackgroundBrush" Color="#DCE6EF"/>
    <SolidColorBrush x:Key="AppSelectionBrush" Color="#2F80C9"/>
    <SolidColorBrush x:Key="AppSelectionTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppMenuBackgroundBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="AppMenuForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppMenuPopupBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppMenuPopupForegroundBrush" Color="#243447"/>
    <SolidColorBrush x:Key="AppMenuHoverBrush" Color="#DCE6EF"/>
    <SolidColorBrush x:Key="AppDisabledButtonBackgroundBrush" Color="#CBD3DB"/>
    <SolidColorBrush x:Key="AppDisabledButtonForegroundBrush" Color="#435363"/>
    <SolidColorBrush x:Key="AppDisabledButtonBorderBrush" Color="#AEB9C4"/>
    <SolidColorBrush x:Key="AppButtonBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppButtonForegroundBrush" Color="#1F2D3A"/>
    <SolidColorBrush x:Key="AppButtonBorderBrush" Color="#C7D2DE"/>
    <SolidColorBrush x:Key="AppButtonHoverOverlayBrush" Color="#123498DB"/>
    <SolidColorBrush x:Key="AppButtonPressedOverlayBrush" Color="#18000000"/>
    <SolidColorBrush x:Key="AppButtonFocusBorderBrush" Color="#2F80C9"/>
    <CornerRadius x:Key="AppButtonCornerRadius">9</CornerRadius>

    <SolidColorBrush x:Key="AppPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#7F8C8D"/>

    <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppInputForegroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="AppAccentBrush" Color="#3498DB"/>

    <SolidColorBrush x:Key="AppHighlightBrush" Color="#34495E"/>
    <Color x:Key="AppHighlightColor">#34495E</Color>

    <SolidColorBrush x:Key="ConfiguratorSidebarBackgroundBrush" Color="#223241"/>
    <SolidColorBrush x:Key="ConfiguratorHeaderBackgroundBrush" Color="#132231"/>
    <SolidColorBrush x:Key="ConfiguratorSidebarCardBrush" Color="#2D4052"/>
    <SolidColorBrush x:Key="ConfiguratorTreeItemForegroundBrush" Color="#F6FAFD"/>
    <SolidColorBrush x:Key="ConfiguratorTreeGroupForegroundBrush" Color="#B9C8D6"/>
    <SolidColorBrush x:Key="ConfiguratorTreeItemHoverBrush" Color="#3A5064"/>
    <SolidColorBrush x:Key="ConfiguratorTreeItemSelectedBrush" Color="#2F80C9"/>
    <SolidColorBrush x:Key="ConfiguratorPatchBadgeBackgroundBrush" Color="#EAF4FF"/>
    <SolidColorBrush x:Key="ConfiguratorPatchBadgeForegroundBrush" Color="#143A57"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
    </Style>
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource AppMenuBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppMenuForegroundBrush}"/>
    </Style>
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{DynamicResource AppMenuPopupBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppMenuPopupForegroundBrush}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Style.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Background" Value="{DynamicResource AppMenuBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppMenuForegroundBrush}"/>
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
                <Setter Property="Background" Value="{DynamicResource AppMenuBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppMenuForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppMenuHoverBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource AppDisabledButtonForegroundBrush}"/>
                <Setter Property="Opacity" Value="0.78"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="Button">
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Background" Value="{DynamicResource AppButtonBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppButtonForegroundBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBorderBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource AppButtonCornerRadius}"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Border x:Name="ButtonOverlay"
                                    Background="Transparent"
                                    CornerRadius="{DynamicResource AppButtonCornerRadius}"
                                    Opacity="0"/>
                            <ContentPresenter x:Name="ButtonContent"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppButtonFocusBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppButtonFocusBorderBrush}"/>
                            <Setter TargetName="ButtonOverlay" Property="Background" Value="{DynamicResource AppButtonHoverOverlayBrush}"/>
                            <Setter TargetName="ButtonOverlay" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonOverlay" Property="Background" Value="{DynamicResource AppButtonPressedOverlayBrush}"/>
                            <Setter TargetName="ButtonOverlay" Property="Opacity" Value="1"/>
                            <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.985" ScaleY="0.985"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppDisabledButtonBackgroundBrush}"/>
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppDisabledButtonBorderBrush}"/>
                            <Setter TargetName="ButtonContent" Property="TextElement.Foreground" Value="{DynamicResource AppDisabledButtonForegroundBrush}"/>
                            <Setter TargetName="ButtonOverlay" Property="Opacity" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="RowBackground" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppAlternateRowBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource AppTableHeaderBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="7,6"/>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
    </Style>
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
    </Style>

</ResourceDictionary>
