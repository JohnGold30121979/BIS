<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Светлая тема -->
    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="AppSidebarBackgroundBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#1A252F"/>
    <SolidColorBrush x:Key="AppContentBackgroundBrush" Color="#F5F6FA"/>

    <SolidColorBrush x:Key="AppPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#7F8C8D"/>

    <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppInputForegroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="AppAccentBrush" Color="#3498DB"/>

    <SolidColorBrush x:Key="AppHighlightBrush" Color="#34495E"/>
    <Color x:Key="AppHighlightColor">#34495E</Color>

</ResourceDictionary>