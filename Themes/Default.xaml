<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Светлая тема -->
    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="AppSidebarBackgroundBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#1A252F"/>
    <SolidColorBrush x:Key="AppContentBackgroundBrush" Color="#F5F6FA"/>
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppAlternateRowBrush" Color="#F4F7F9"/>
    <SolidColorBrush x:Key="AppBorderBrush" Color="#D7DEE5"/>
    <SolidColorBrush x:Key="AppReadOnlyBackgroundBrush" Color="#E9EDF1"/>
    <SolidColorBrush x:Key="AppBodyTextBrush" Color="#243447"/>
    <SolidColorBrush x:Key="AppTableHeaderBackgroundBrush" Color="#DCE6EF"/>
    <SolidColorBrush x:Key="AppSelectionBrush" Color="#2F80C9"/>
    <SolidColorBrush x:Key="AppSelectionTextBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="AppPrimaryTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#7F8C8D"/>

    <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppInputForegroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="AppAccentBrush" Color="#3498DB"/>

    <SolidColorBrush x:Key="AppHighlightBrush" Color="#34495E"/>
    <Color x:Key="AppHighlightColor">#34495E</Color>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="RowBackground" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppAlternateRowBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource AppTableHeaderBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="7,6"/>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
    </Style>
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
    </Style>

</ResourceDictionary>
