<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Темная тема -->
    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="AppSidebarBackgroundBrush" Color="#1E1E2A"/>
    <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#0D0D14"/>
    <SolidColorBrush x:Key="AppContentBackgroundBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#24283B"/>
    <SolidColorBrush x:Key="AppAlternateRowBrush" Color="#2B3047"/>
    <SolidColorBrush x:Key="AppBorderBrush" Color="#46506A"/>
    <SolidColorBrush x:Key="AppReadOnlyBackgroundBrush" Color="#30364D"/>
    <SolidColorBrush x:Key="AppBodyTextBrush" Color="#E8ECF3"/>
    <SolidColorBrush x:Key="AppTableHeaderBackgroundBrush" Color="#353C55"/>
    <SolidColorBrush x:Key="AppSelectionBrush" Color="#2878B8"/>
    <SolidColorBrush x:Key="AppSelectionTextBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="AppPrimaryTextBrush" Color="#ECF0F1"/>
    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#95A5A6"/>

    <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="AppInputForegroundBrush" Color="#ECF0F1"/>
    <SolidColorBrush x:Key="AppAccentBrush" Color="#3498DB"/>

    <SolidColorBrush x:Key="AppHighlightBrush" Color="#2A3A4A"/>
    <Color x:Key="AppHighlightColor">#2A3A4A</Color>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="RowBackground" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppAlternateRowBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource AppTableHeaderBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="7,6"/>
    </Style>
    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
    </Style>
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
    </Style>

</ResourceDictionary>
