<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">

    <!-- Темная тема -->
    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="AppSidebarBackgroundBrush" Color="#1E1E2A"/>
    <SolidColorBrush x:Key="AppHeaderBackgroundBrush" Color="#0D0D14"/>
    <SolidColorBrush x:Key="AppContentBackgroundBrush" Color="#1A1A2E"/>
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#24283B"/>
    <SolidColorBrush x:Key="AppAlternateRowBrush" Color="#2B3047"/>
    <SolidColorBrush x:Key="AppBorderBrush" Color="#46506A"/>
    <SolidColorBrush x:Key="AppReadOnlyBackgroundBrush" Color="#30364D"/>
    <SolidColorBrush x:Key="AppBodyTextBrush" Color="#E8ECF3"/>
    <SolidColorBrush x:Key="AppTableHeaderBackgroundBrush" Color="#353C55"/>
    <SolidColorBrush x:Key="AppTableHeaderForegroundBrush" Color="#F4F7FB"/>
    <SolidColorBrush x:Key="AppSelectionBrush" Color="#2878B8"/>
    <SolidColorBrush x:Key="AppSelectionTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppMenuBackgroundBrush" Color="#171B28"/>
    <SolidColorBrush x:Key="AppMenuForegroundBrush" Color="#F4F7FB"/>
    <SolidColorBrush x:Key="AppMenuPopupBackgroundBrush" Color="#2B3044"/>
    <SolidColorBrush x:Key="AppMenuPopupForegroundBrush" Color="#F0F3F8"/>
    <SolidColorBrush x:Key="AppMenuHoverBrush" Color="#3C4965"/>
    <SolidColorBrush x:Key="AppDisabledButtonBackgroundBrush" Color="#3B4258"/>
    <SolidColorBrush x:Key="AppDisabledButtonForegroundBrush" Color="#C3CAD7"/>
    <SolidColorBrush x:Key="AppDisabledButtonBorderBrush" Color="#56617A"/>
    <SolidColorBrush x:Key="AppButtonBackgroundBrush" Color="#2C344A"/>
    <SolidColorBrush x:Key="AppButtonForegroundBrush" Color="#F2F6FB"/>
    <SolidColorBrush x:Key="AppButtonBorderBrush" Color="#53617A"/>
    <SolidColorBrush x:Key="AppButtonHoverOverlayBrush" Color="#18FFFFFF"/>
    <SolidColorBrush x:Key="AppButtonPressedOverlayBrush" Color="#26000000"/>
    <SolidColorBrush x:Key="AppButtonFocusBorderBrush" Color="#4AA3DF"/>
    <CornerRadius x:Key="AppButtonCornerRadius">9</CornerRadius>

    <SolidColorBrush x:Key="AppPrimaryTextBrush" Color="#ECF0F1"/>
    <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#95A5A6"/>
    <SolidColorBrush x:Key="AppBrandShellBackgroundBrush" Color="#151923"/>
    <SolidColorBrush x:Key="AppBrandHeaderBackgroundBrush" Color="#0A0D14"/>
    <SolidColorBrush x:Key="AppBrandIconForegroundBrush" Color="#8AB4F8"/>
    <SolidColorBrush x:Key="AppBrandTitleForegroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="AppBrandSubtitleForegroundBrush" Color="#D2DEEC"/>
    <SolidColorBrush x:Key="AppBrandStatusForegroundBrush" Color="#AEBED0"/>
    <SolidColorBrush x:Key="AppNavigationForegroundBrush" Color="#F4F7FB"/>
    <SolidColorBrush x:Key="AppNavigationMutedForegroundBrush" Color="#B8C7D9"/>

    <SolidColorBrush x:Key="AppInputBackgroundBrush" Color="#2C3E50"/>
    <SolidColorBrush x:Key="AppInputForegroundBrush" Color="#ECF0F1"/>
    <SolidColorBrush x:Key="AppAccentBrush" Color="#3498DB"/>

    <SolidColorBrush x:Key="AppHighlightBrush" Color="#2A3A4A"/>
    <Color x:Key="AppHighlightColor">#2A3A4A</Color>

    <SolidColorBrush x:Key="ConfiguratorSidebarBackgroundBrush" Color="#151923"/>
    <SolidColorBrush x:Key="ConfiguratorHeaderBackgroundBrush" Color="#0A0D14"/>
    <SolidColorBrush x:Key="ConfiguratorSidebarCardBrush" Color="#232A3D"/>
    <SolidColorBrush x:Key="ConfiguratorTreeItemForegroundBrush" Color="#F0F4FA"/>
    <SolidColorBrush x:Key="ConfiguratorTreeGroupForegroundBrush" Color="#9DAAC0"/>
    <SolidColorBrush x:Key="ConfiguratorTreeItemHoverBrush" Color="#303A52"/>
    <SolidColorBrush x:Key="ConfiguratorTreeItemSelectedBrush" Color="#2878B8"/>
    <SolidColorBrush x:Key="ConfiguratorPatchBadgeBackgroundBrush" Color="#20344B"/>
    <SolidColorBrush x:Key="ConfiguratorPatchBadgeForegroundBrush" Color="#D9ECFF"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource AppWindowBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
    </Style>
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{DynamicResource AppMenuBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppMenuForegroundBrush}"/>
    </Style>
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{DynamicResource AppMenuPopupBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppMenuPopupForegroundBrush}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Style.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Background" Value="{DynamicResource AppMenuBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppMenuForegroundBrush}"/>
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
                <Setter Property="Background" Value="{DynamicResource AppMenuBackgroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppMenuForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppMenuHoverBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppMenuPopupForegroundBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource AppDisabledButtonForegroundBrush}"/>
                <Setter Property="Opacity" Value="0.82"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="Button">
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Background" Value="{DynamicResource AppButtonBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppButtonForegroundBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBorderBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource AppButtonCornerRadius}"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Border x:Name="ButtonOverlay"
                                    Background="Transparent"
                                    CornerRadius="{DynamicResource AppButtonCornerRadius}"
                                    Opacity="0"/>
                            <ContentPresenter x:Name="ButtonContent"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppButtonFocusBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppButtonFocusBorderBrush}"/>
                            <Setter TargetName="ButtonOverlay" Property="Background" Value="{DynamicResource AppButtonHoverOverlayBrush}"/>
                            <Setter TargetName="ButtonOverlay" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonOverlay" Property="Background" Value="{DynamicResource AppButtonPressedOverlayBrush}"/>
                            <Setter TargetName="ButtonOverlay" Property="Opacity" Value="1"/>
                            <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.985" ScaleY="0.985"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppDisabledButtonBackgroundBrush}"/>
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppDisabledButtonBorderBrush}"/>
                            <Setter TargetName="ButtonContent" Property="TextElement.Foreground" Value="{DynamicResource AppDisabledButtonForegroundBrush}"/>
                            <Setter TargetName="ButtonOverlay" Property="Opacity" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource AppInputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="ColumnHeaderStyle" Value="{DynamicResource AppDataGridColumnHeaderStyle}"/>
        <Setter Property="RowBackground" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppAlternateRowBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource AppBorderBrush}"/>
    </Style>
    <Style x:Key="AppDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource AppTableHeaderBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppTableHeaderForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="7,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Grid>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <primitives:Thumb x:Name="PART_LeftHeaderGripper"
                                          Width="8"
                                          HorizontalAlignment="Left"
                                          Background="Transparent"
                                          Cursor="SizeWE">
                            <primitives:Thumb.Template>
                                <ControlTemplate TargetType="primitives:Thumb">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </primitives:Thumb.Template>
                        </primitives:Thumb>
                        <primitives:Thumb x:Name="PART_RightHeaderGripper"
                                          Width="8"
                                          HorizontalAlignment="Right"
                                          Background="Transparent"
                                          Cursor="SizeWE">
                            <primitives:Thumb.Template>
                                <ControlTemplate TargetType="primitives:Thumb">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </primitives:Thumb.Template>
                        </primitives:Thumb>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource AppDataGridColumnHeaderStyle}"/>
    <Style TargetType="DataGridCell">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppInputForegroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
    </Style>
    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AppBodyTextBrush}"/>
    </Style>

</ResourceDictionary>
